@page "/dashboard"
@inject IJSRuntime JS
@using System.Collections.Generic

<div class="vegalite-container">
    <div class="header-section">
        <h1>📊 Vega-Lite Visualization Gallery</h1>
        <p class="subtitle">Interactive & powerful declarative visualizations for exploratory data analysis</p>
    </div>

    <!-- Chart Grid Container -->
    <div class="charts-grid">
        <!-- Chart 1: Scatter Plot with Trend -->
        <div class="chart-card">
            <div class="chart-title">Correlation Analysis - Scatter Plot</div>
            <div id="scatterChart" class="chart-container"></div>
            <p class="chart-desc">Showing relationship between variables with color encoding</p>
        </div>

        <!-- Chart 2: Line Chart with Multiple Series -->
        <div class="chart-card">
            <div class="chart-title">Time Series - Line Chart</div>
            <div id="lineChart" class="chart-container"></div>
            <p class="chart-desc">Sales trend over months with smooth interpolation</p>
        </div>

        <!-- Chart 3: Bar Chart -->
        <div class="chart-card">
            <div class="chart-title">Category Comparison - Bar Chart</div>
            <div id="barChart" class="chart-container"></div>
            <p class="chart-desc">Revenue by product category with sorting</p>
        </div>

        <!-- Chart 4: Donut Chart -->
        <div class="chart-card">
            <div class="chart-title">Composition - Donut Chart</div>
            <div id="pieChart" class="chart-container"></div>
            <p class="chart-desc">Market share distribution by region</p>
        </div>

        <!-- Chart 5: Histogram -->
        <div class="chart-card">
            <div class="chart-title">Distribution - Histogram</div>
            <div id="histogramChart" class="chart-container"></div>
            <p class="chart-desc">Frequency distribution of data values</p>
        </div>

        <!-- Chart 6: Box Plot -->
        <div class="chart-card">
            <div class="chart-title">Statistical Summary - Box Plot</div>
            <div id="boxPlotChart" class="chart-container"></div>
            <p class="chart-desc">Data quartiles and outlier detection</p>
        </div>

        <!-- Chart 7: Area Chart -->
        <div class="chart-card wide-chart">
            <div class="chart-title">Cumulative Trend - Area Chart</div>
            <div id="areaChart" class="chart-container"></div>
            <p class="chart-desc">Stacked area showing contributions over time</p>
        </div>

        <!-- Chart 8: Heatmap -->
        <div class="chart-card wide-chart">
            <div class="chart-title">Pattern Recognition - Heatmap</div>
            <div id="heatmapChart" class="chart-container"></div>
            <p class="chart-desc">Intensity matrix visualization for correlation patterns</p>
        </div>
    </div>

    <style>
            .vegalite-container {
                background: linear-gradient(135deg, #f5f7fa 0%, #c3cfe2 100%);
                min-height: 100vh;
                padding: 40px 20px;
            }

            .header-section {
                text-align: center;
                margin-bottom: 50px;
                color: #333;
            }

            .header-section h1 {
                font-size: 2.5em;
                margin-bottom: 10px;
                font-weight: 700;
            }

            .subtitle {
                font-size: 1.1em;
                color: #666;
                max-width: 600px;
                margin: 0 auto;
            }

            .charts-grid {
                display: grid;
                grid-template-columns: repeat(auto-fit, minmax(500px, 1fr));
                gap: 30px;
                max-width: 1600px;
                margin: 0 auto;
            }

            .chart-card {
                background: white;
                border-radius: 12px;
                padding: 25px;
                box-shadow: 0 8px 16px rgba(0, 0, 0, 0.1);
                transition: transform 0.3s ease, box-shadow 0.3s ease;
            }

            .chart-card:hover {
                transform: translateY(-5px);
                box-shadow: 0 12px 24px rgba(0, 0, 0, 0.15);
            }

            .chart-card.wide-chart {
                grid-column: span 2;
            }

            .chart-title {
                font-size: 1.3em;
                font-weight: 600;
                color: #2c3e50;
                margin-bottom: 15px;
                border-bottom: 3px solid #3F51B5;
                padding-bottom: 10px;
            }

            .chart-container {
                min-height: 350px;
                display: flex;
                align-items: center;
                justify-content: center;
                margin: 15px 0;
            }

            .chart-desc {
                font-size: 0.9em;
                color: #7f8c8d;
                margin-top: 12px;
                font-style: italic;
            }

            @@media (max-width: 768px) {
                .charts-grid {
                    grid-template-columns: 1fr;
                }

                .chart-card.wide-chart {
                    grid-column: span 1;
                }

                .header-section h1 {
                    font-size: 1.8em;
                }
            }
    </style>
</div>

@code {

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (!firstRender) return;

        // ==================== DATA ====================
        var salesData = new[]
        {
            new { month="Jan", revenue=45, region="US" },
            new { month="Feb", revenue=62, region="US" },
            new { month="Mar", revenue=55, region="US" },
            new { month="Apr", revenue=78, region="US" },
            new { month="May", revenue=85, region="US" },
            new { month="Jun", revenue=92, region="US" }
        };

        var scatterData = new[]
        {
            new { marketing=10, sales=30, region="North" },
            new { marketing=20, sales=50, region="North" },
            new { marketing=30, sales=65, region="North" },
            new { marketing=40, sales=80, region="North" },
            new { marketing=15, sales=35, region="South" },
            new { marketing=25, sales=55, region="South" },
            new { marketing=35, sales=75, region="South" },
            new { marketing=45, sales=85, region="South" }
        };

        var productData = new[]
        {
            new { product="Product A", revenue=48 },
            new { product="Product B", revenue=72 },
            new { product="Product C", revenue=35 },
            new { product="Product D", revenue=62 },
            new { product="Product E", revenue=58 }
        };

        var regionData = new[]
        {
            new { region="North America", value=40 },
            new { region="Europe", value=25 },
            new { region="Asia Pacific", value=20 },
            new { region="Other", value=15 }
        };

        var distributionData = new[]
        {
            new { value=10 }, new { value=15 }, new { value=18 }, new { value=25 }, new { value=30 },
            new { value=32 }, new { value=35 }, new { value=38 }, new { value=40 }, new { value=42 },
            new { value=45 }, new { value=48 }, new { value=50 }, new { value=52 }, new { value=55 }
        };

        var boxPlotData = new[]
        {
            new { category="Q1", value=15 }, new { category="Q1", value=20 }, new { category="Q1", value=25 },
            new { category="Q1", value=30 }, new { category="Q1", value=35 }, new { category="Q1", value=40 },
            new { category="Q2", value=25 }, new { category="Q2", value=30 }, new { category="Q2", value=35 },
            new { category="Q2", value=40 }, new { category="Q2", value=45 }, new { category="Q2", value=50 },
            new { category="Q3", value=35 }, new { category="Q3", value=40 }, new { category="Q3", value=45 },
            new { category="Q3", value=50 }, new { category="Q3", value=55 }, new { category="Q3", value=60 }
        };

        var heatmapData = new[]
        {
            new { x="Monday", y="Morning", value=5 }, new { x="Monday", y="Afternoon", value=8 },
            new { x="Tuesday", y="Morning", value=7 }, new { x="Tuesday", y="Afternoon", value=9 },
            new { x="Wednesday", y="Morning", value=6 }, new { x="Wednesday", y="Afternoon", value=7 },
            new { x="Thursday", y="Morning", value=9 }, new { x="Thursday", y="Afternoon", value=10 },
            new { x="Friday", y="Morning", value=8 }, new { x="Friday", y="Afternoon", value=12 }
        };

        // ==================== SCATTER PLOT (INTERACTIVE) ====================
        var scatterSpec = new Dictionary<string, object>
        {
            ["$schema"] = "https://vega.github.io/schema/vega-lite/v5.json",
            ["description"] = "Interactive scatter plot - hover over points for details",
            ["data"] = new Dictionary<string, object> { ["values"] = scatterData },
            ["selection"] = new Dictionary<string, object>
            {
                ["hover"] = new { type = "single", on = "mouseover", empty = "none" }
            },
            ["mark"] = new { type = "point", size = 150, filled = true },
            ["encoding"] = new Dictionary<string, object>
            {
                ["x"] = new { field = "marketing", type = "quantitative", title = "Marketing Spend ($K)" },
                ["y"] = new { field = "sales", type = "quantitative", title = "Sales Revenue ($K)" },
                ["color"] = new { field = "region", type = "nominal", title = "Region" },
                ["opacity"] = new { condition = new { param = "hover", value = 1 }, value = 0.4 },
                ["size"] = new { condition = new { param = "hover", value = 300 }, value = 150 },
                ["tooltip"] = new object[]
                {
                    new { field = "marketing", type = "quantitative", title = "Marketing Spend" },
                    new { field = "sales", type = "quantitative", title = "Sales Revenue" },
                    new { field = "region", type = "nominal", title = "Region" }
                }
            }
        };

        // ==================== LINE CHART (INTERACTIVE) ====================
        var lineSpec = new Dictionary<string, object>
        {
            ["$schema"] = "https://vega.github.io/schema/vega-lite/v5.json",
            ["data"] = new Dictionary<string, object> { ["values"] = salesData },
            ["selection"] = new Dictionary<string, object>
            {
                ["pointHover"] = new { type = "single", on = "mouseover", nearest = true, empty = "none" }
            },
            ["mark"] = new { type = "line", point = true, color = "#FF6F00", size = 150 },
            ["encoding"] = new Dictionary<string, object>
            {
                ["x"] = new
                {
                    field = "month",
                    type = "ordinal",
                    title = "Month",
                    sort = new[] { "Jan", "Feb", "Mar", "Apr", "May",
"Jun" }
                },
                ["y"] = new { field = "revenue", type = "quantitative", title = "Revenue ($K)" },
                ["strokeWidth"] = new { condition = new { param = "pointHover", value = 4 }, value = 2 },
                ["opacity"] = new { value = 1 },
                ["tooltip"] = new object[]
                {
                    new { field = "month", type = "ordinal", title = "Month" },
                    new { field = "revenue", type = "quantitative", title = "Revenue ($K)" },
                    new { field = "region", type = "nominal", title = "Region" }
                }
            }
        };

        // ==================== BAR CHART (INTERACTIVE) ====================
        var barSpec = new Dictionary<string, object>
        {
            ["$schema"] = "https://vega.github.io/schema/vega-lite/v5.json",
            ["data"] = new Dictionary<string, object> { ["values"] = productData },
            ["selection"] = new Dictionary<string, object>
            {
                ["barSelect"] = new { type = "single", on = "click" }
            },
            ["mark"] = new { type = "bar", cornerRadius = 4 },
            ["encoding"] = new Dictionary<string, object>
            {
                ["x"] = new { field = "product", type = "nominal", title = "Product" },
                ["y"] = new { field = "revenue", type = "quantitative", title = "Revenue ($K)" },
                ["color"] = new { condition = new { param = "barSelect", value = "#FF6F00" }, value = "#4A90E2" },
                ["opacity"] = new { condition = new { param = "barSelect", value = 1 }, value = 0.6 },
                ["tooltip"] = new object[]
                {
                    new { field = "product", type = "nominal", title = "Product" },
                    new { field = "revenue", type = "quantitative", title = "Revenue", format = "$,.0f" }
                }
            },
            ["sort"] = new { encoding = "y", order = "descending" }
        };

        // ==================== DONUT CHART (INTERACTIVE) ====================
        var pieSpec = new Dictionary<string, object>
        {
            ["$schema"] = "https://vega.github.io/schema/vega-lite/v5.json",
            ["data"] = new Dictionary<string, object> { ["values"] = regionData },
            ["selection"] = new Dictionary<string, object>
            {
                ["click"] = new { type = "single", on = "click", empty = "all" }
            },
            ["mark"] = new { type = "arc", innerRadius = 60, cornerRadius = 4, padAngle = 0.02 },
            ["encoding"] = new Dictionary<string, object>
            {
                ["theta"] = new { field = "value", type = "quantitative", stack = true },
                ["color"] = new { field = "region", type = "nominal", title = "Region" },
                ["opacity"] = new { condition = new { param = "click", field = "region", value = 0.9 }, value = 0.5 },
                ["tooltip"] = new object[]
                {
                    new { field = "region", type = "nominal", title = "Region" },
                    new { field = "value", type = "quantitative", title = "Market Share" }
                }
            }
        };

        // ==================== HISTOGRAM (INTERACTIVE) ====================
        var histogramSpec = new Dictionary<string, object>
        {
            ["$schema"] = "https://vega.github.io/schema/vega-lite/v5.json",
            ["data"] = new Dictionary<string, object> { ["values"] = distributionData },
            ["selection"] = new Dictionary<string, object>
            {
                ["brush"] = new { type = "interval", encodings = new[] { "x" } }
            },
            ["mark"] = new { type = "bar", cornerRadius = 3 },
            ["encoding"] = new Dictionary<string, object>
            {
                ["x"] = new { field = "value", type = "quantitative", bin = new { maxbins = 15 }, title = "Value Bins" },
                ["y"] = new { aggregate = "count", type = "quantitative", title = "Frequency" },
                ["color"] = new { condition = new { param = "brush", value = "#4caf50" }, value = "#81C784" },
                ["opacity"] = new { condition = new { param = "brush", value = 1 }, value = 0.5 },
                ["tooltip"] = new object[]
                {
                    new { aggregate = "count", type = "quantitative", title = "Count" },
                    new { field = "value", type = "quantitative", title = "Value Min", bin = new { maxbins = 15 } }
                }
            }
        };

        // ==================== BOX PLOT (INTERACTIVE) ====================
        var boxPlotSpec = new Dictionary<string, object>
        {
            ["$schema"] = "https://vega.github.io/schema/vega-lite/v5.json",
            ["data"] = new Dictionary<string, object> { ["values"] = boxPlotData },
            ["selection"] = new Dictionary<string, object>
            {
                ["categoryHover"] = new { type = "single", on = "mouseover", encodings = new[] { "x" }, empty = "none" }
            },
            ["mark"] = new { type = "boxplot", extent = "min-max" },
            ["encoding"] = new Dictionary<string, object>
            {
                ["x"] = new { field = "category", type = "nominal", title = "Quarter" },
                ["y"] = new { field = "value", type = "quantitative", title = "Value" },
                ["color"] = new { condition = new { param = "categoryHover", value = "field" }, field = "category", type = "nominal" },
                ["opacity"] = new { condition = new { param = "categoryHover", value = 0.9 }, value = 0.5 },
                ["tooltip"] = new object[]
                {
                    new { field = "category", type = "nominal", title = "Quarter" },
                    new { field = "value", type = "quantitative", title = "Value", aggregate = "min" }
                }
            }
        };

        // ==================== AREA CHART (INTERACTIVE) ====================
        var areaSpec = new Dictionary<string, object>
        {
            ["$schema"] = "https://vega.github.io/schema/vega-lite/v5.json",
            ["data"] = new Dictionary<string, object> { ["values"] = salesData },
            ["selection"] = new Dictionary<string, object>
            {
                ["grid"] = new { type = "interval", bind = "scales" }
            },
            ["mark"] = new
            {
                type = "area",
                opacity = 0.7,
                interpolate = "monotone",
                line = new { color = "#2196F3" },
                point = true
            },
            ["encoding"] = new Dictionary<string, object>
            {
                ["x"] = new
                {
                    field = "month",
                    type = "ordinal",
                    title = "Month",
                    sort = new[] { "Jan", "Feb", "Mar", "Apr", "May",
"Jun" }
                },
                ["y"] = new { field = "revenue", type = "quantitative", title = "Revenue ($K)" },
                ["color"] = new { value = "#2196F3" },
                ["opacity"] = new { value = 0.8 },
                ["tooltip"] = new object[]
                {
                    new { field = "month", type = "ordinal", title = "Month" },
                    new { field = "revenue", type = "quantitative", title = "Revenue ($K)" }
                }
            }
        };

        // ==================== HEATMAP (INTERACTIVE) ====================
        var heatmapSpec = new Dictionary<string, object>
        {
            ["$schema"] = "https://vega.github.io/schema/vega-lite/v5.json",
            ["data"] = new Dictionary<string, object> { ["values"] = heatmapData },
            ["selection"] = new Dictionary<string, object>
            {
                ["cellHover"] = new { type = "single", on = "mouseover", empty = "none" }
            },
            ["mark"] = new { type = "rect", stroke = "white", strokeWidth = 2 },
            ["encoding"] = new Dictionary<string, object>
            {
                ["x"] = new { field = "x", type = "nominal", title = "Day" },
                ["y"] = new { field = "y", type = "nominal", title = "Time" },
                ["color"] = new { field = "value", type = "quantitative", scale = new { scheme = "reds" }, title = "Intensity" },
                ["opacity"] = new { condition = new { param = "cellHover", value = 1 }, value = 0.8 },
                ["size"] = new { condition = new { param = "cellHover", value = 300 }, value = 100 },
                ["tooltip"] = new object[]
                {
                    new { field = "x", type = "nominal", title = "Day" },
                    new { field = "y", type = "nominal", title = "Time" },
                    new { field = "value", type = "quantitative", title = "Activity Level" }
                }
            }
        };

        // Render all charts
        await JS.InvokeVoidAsync("renderVegaFromSpec", "scatterChart", scatterSpec);
        await JS.InvokeVoidAsync("renderVegaFromSpec", "lineChart", lineSpec);
        await JS.InvokeVoidAsync("renderVegaFromSpec", "barChart", barSpec);
        await JS.InvokeVoidAsync("renderVegaFromSpec", "pieChart", pieSpec);
        await JS.InvokeVoidAsync("renderVegaFromSpec", "histogramChart", histogramSpec);
        await JS.InvokeVoidAsync("renderVegaFromSpec", "boxPlotChart", boxPlotSpec);
        await JS.InvokeVoidAsync("renderVegaFromSpec", "areaChart", areaSpec);
        await JS.InvokeVoidAsync("renderVegaFromSpec", "heatmapChart", heatmapSpec);
    }
}