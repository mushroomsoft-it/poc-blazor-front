@page "/linechart"
@inject IJSRuntime JS
@inject HttpClient Http
@using System.Collections.Generic
@using System.Text.Json

<div class="page-wrapper">

    <h1 class="title">Vega-Lite Advanced Analytics</h1>
    <p class="subtitle">
        Multi-series · Zoom · Promedio automático · Interactividad real
    </p>

    <div class="chart-card">
        <div id="lineMainChart"></div>
    </div>

</div>

<style>
    .page-wrapper {
        min-height: 100vh;
        padding: 50px;
        background: linear-gradient(135deg, #0f2027, #203a43, #2c5364);
        font-family: Segoe UI, sans-serif;
        color: white;
    }

    .title {
        text-align: center;
        font-size: 40px;
        font-weight: 600;
    }

    .subtitle {
        text-align: center;
        margin-bottom: 40px;
        opacity: 0.8;
    }

    .chart-card {
        background: white;
        border-radius: 16px;
        padding: 30px;
        max-width: 1100px;
        margin: auto;
        box-shadow: 0 25px 50px rgba(0, 0, 0, 0.3);
    }
</style>

@code {

    private class LineChartRecord
    {
        public string? Date { get; set; }
        public double Value { get; set; }
        public string? Series { get; set; }
    }

    private List<object> data = new();

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (!firstRender) return;

        await GenerateDataFromJson();
        await RenderChart();
    }

    private async Task GenerateDataFromJson()
    {
        try
        {
            var json = await Http.GetStringAsync("sample-data/linechart-data.json");
            var options = new JsonSerializerOptions { PropertyNameCaseInsensitive = true };
            var records = JsonSerializer.Deserialize<List<LineChartRecord>>(json, options);

            if (records != null && records.Count > 0)
            {
                data = records.Select(r => new
                {
                    date = DateTime.Parse(r.Date ?? DateTime.Now.ToString()),
                    value = r.Value,
                    series = r.Series ?? ""
                }).Cast<object>().ToList();
                Console.WriteLine($"LineChart data loaded successfully: {data.Count} records");
            }
            else
            {
                Console.WriteLine("No records found in linechart JSON");
            }
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Error loading linechart JSON data: {ex.Message}");
            Console.WriteLine($"Stack trace: {ex.StackTrace}");
        }
    }

    private async Task RenderChart()
    {
        // Crear datos para las líneas horizontales con colores específicos
        var gridLines = new List<object>
        {
            // 45: Color Gris
            new { value = 45, color = "#95a5a6" },
            // Rango 50-55: Color Azul
            new { value = 50, color = "#3498db" },
            new { value = 55, color = "#3498db" },
            // Rango 60-65: Color Verde
            new { value = 60, color = "#2ecc71" },
            new { value = 65, color = "#2ecc71" },
            // Rango 70-75: Color Naranja
            new { value = 70, color = "#e74c3c" },
            new { value = 75, color = "#e74c3c" },
            // Rango 80-85: Color Púrpura
            new { value = 80, color = "#9b59b6" },
            new { value = 85, color = "#9b59b6" },
            // 90: Color Dorado
            new { value = 90, color = "#f39c12" }
        };

        var spec = new Dictionary<string, object>
        {
            ["$schema"] = "https://vega.github.io/schema/vega-lite/v5.json",

            ["width"] = 1000,
            ["height"] = 450,

            ["autosize"] = new Dictionary<string, object>
            {
                ["type"] = "fit",
                ["contains"] = "padding"
            },

            ["data"] = new Dictionary<string, object>
            {
                ["values"] = data
            },

            ["transform"] = new object[]
            {
                // Si necesitas transformar datos, aquí iría
            },

            ["resolve"] = new Dictionary<string, object>
            {
                ["scale"] = new Dictionary<string, object> { ["color"] = "independent" }
            },

            ["layer"] = new object[]
            {
                // Capa de líneas de grid personalizadas
                new Dictionary<string, object>
                {
                    ["data"] = new Dictionary<string, object> { ["values"] = gridLines },
                    ["mark"] = new Dictionary<string, object>
                    {
                        ["type"] = "rule",
                        ["size"] = 2,
                        ["opacity"] = 0.7
                    },
                    ["encoding"] = new Dictionary<string, object>
                    {
                        ["y"] = new Dictionary<string, object>
                        {
                            ["field"] = "value",
                            ["type"] = "quantitative"
                        },
                        ["color"] = new Dictionary<string, object>
                        {
                            ["field"] = "color",
                            ["type"] = "nominal",
                            ["scale"] = new Dictionary<string, object> { ["domain"] = new[] { "#95a5a6", "#3498db", "#2ecc71", "#e74c3c", "#9b59b6",
"#f39c12" },
["range"] = new[] { "#95a5a6", "#3498db", "#2ecc71", "#e74c3c", "#9b59b6", "#f39c12" } },
                            ["legend"] = null
                        }
                    }
                },

                // Capa de líneas principales
                new Dictionary<string, object>
                {
                    ["mark"] = new Dictionary<string, object>
                    {
                        ["type"] = "line",
                        ["point"] = true,
                        ["interpolate"] = "monotone"
                    },

                    ["encoding"] = new Dictionary<string, object>
                    {
                        ["x"] = new Dictionary<string, object>
                        {
                            ["field"] = "date",
                            ["type"] = "temporal",
                            ["title"] = "Fecha",
                            ["format"] = "%Y-%m-%d",
                            ["axis"] = new Dictionary<string, object>
                            {
                                ["format"] = "%Y-%m-%d",
                                ["labelAngle"] = -45,
                                ["labelAlign"] = "right"
                            }
                        },

                        ["y"] = new Dictionary<string, object>
                        {
                            ["field"] = "value",
                            ["type"] = "quantitative",
                            ["title"] = "Revenue",
                            ["scale"] = new Dictionary<string, object>
                            {
                                ["zero"] = false
                            }
                        },

                        ["color"] = new Dictionary<string, object>
                        {
                            ["field"] = "series",
                            ["type"] = "nominal",
                            ["title"] = "Producto"
                        },

                        ["tooltip"] = new object[]
                        {
                            new Dictionary<string, object>
                            {
                                ["field"] = "series",
                                ["type"] = "nominal"
                            },
                            new Dictionary<string, object>
                            {
                                ["field"] = "value",
                                ["type"] = "quantitative"
                            }
                        }
                    }
                },

                // Línea promedio automática
                new Dictionary<string, object>
                {
                    ["mark"] = new Dictionary<string, object>
                    {
                        ["type"] = "rule",
                        ["color"] = "red",
                        ["strokeDash"] = new int[]{5,5}
                    },
                    ["encoding"] = new Dictionary<string, object>
                    {
                        ["y"] = new Dictionary<string, object>
                        {
                            ["aggregate"] = "mean",
                            ["field"] = "value",
                            ["type"] = "quantitative"
                        }
                    }
                }
            },

            ["selection"] = new Dictionary<string, object>
            {
                ["zoom"] = new Dictionary<string, object>
                {
                    ["type"] = "interval",
                    ["bind"] = "scales"
                }
            },

            ["config"] = new Dictionary<string, object>
            {
                ["axis"] = new Dictionary<string, object>
                {
                    ["gridColor"] = "transparent", // Desactivar grid automático
                    ["gridOpacity"] = 0
                }
            }
        };

        await JS.InvokeVoidAsync("renderVegaFromSpec", "lineMainChart", spec);
    }
}