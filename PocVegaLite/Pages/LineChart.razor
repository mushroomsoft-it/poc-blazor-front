@page "/linechart"
@inject IJSRuntime JS

<div class="page-wrapper">

    <h1 class="title">Vega-Lite Advanced Analytics</h1>
    <p class="subtitle">
        Multi-series · Zoom · Promedio automático · Interactividad real
    </p>

    <div class="chart-card">
        <div id="lineMainChart"></div>
    </div>

</div>

<style>
.page-wrapper {
    min-height: 100vh;
    padding: 50px;
    background: linear-gradient(135deg,#0f2027,#203a43,#2c5364);
    font-family: Segoe UI, sans-serif;
    color: white;
}

.title {
    text-align: center;
    font-size: 40px;
    font-weight: 600;
}

.subtitle {
    text-align: center;
    margin-bottom: 40px;
    opacity: 0.8;
}

.chart-card {
    background: white;
    border-radius: 16px;
    padding: 30px;
    max-width: 1100px;
    margin: auto;
    box-shadow: 0 25px 50px rgba(0,0,0,0.3);
}
</style>

@code {

    private List<object> data = new();

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (!firstRender) return;

        GenerateData();
        await RenderChart();
    }

    private void GenerateData()
    {
        var rnd = new Random();
        var series = new[] { "Producto A", "Producto B", "Producto C" };

        for (int i = 0; i < 120; i++)
        {
            foreach (var s in series)
            {
                data.Add(new
                {
                    date = DateTime.Today.AddDays(-120 + i),
                    value = 50 + (i * 0.4) + rnd.NextDouble() * 20,
                    series = s
                });
            }
        }
    }

    private async Task RenderChart()
    {
        var spec = new Dictionary<string, object>
        {
            ["$schema"] = "https://vega.github.io/schema/vega-lite/v5.json",

            ["width"] = 1000,
            ["height"] = 450,

            ["autosize"] = new Dictionary<string, object>
            {
                ["type"] = "fit",
                ["contains"] = "padding"
            },

            ["data"] = new Dictionary<string, object>
            {
                ["values"] = data
            },

            ["layer"] = new object[]
            {
                new Dictionary<string, object>
                {
                    ["mark"] = new Dictionary<string, object>
                    {
                        ["type"] = "line",
                        ["point"] = true,
                        ["interpolate"] = "monotone"
                    },

                    ["encoding"] = new Dictionary<string, object>
                    {
                        ["x"] = new Dictionary<string, object>
                        {
                            ["field"] = "date",
                            ["type"] = "temporal",
                            ["title"] = "Fecha"
                        },

                        ["y"] = new Dictionary<string, object>
                        {
                            ["field"] = "value",
                            ["type"] = "quantitative",
                            ["title"] = "Revenue",
                            ["scale"] = new Dictionary<string, object>
                            {
                                ["zero"] = false
                            }
                        },

                        ["color"] = new Dictionary<string, object>
                        {
                            ["field"] = "series",
                            ["type"] = "nominal",
                            ["title"] = "Producto"
                        },

                        ["tooltip"] = new object[]
                        {
                            new Dictionary<string, object>
                            {
                                ["field"] = "series",
                                ["type"] = "nominal"
                            },
                            new Dictionary<string, object>
                            {
                                ["field"] = "value",
                                ["type"] = "quantitative"
                            }
                        }
                    }
                },

                // Línea promedio automática
                new Dictionary<string, object>
                {
                    ["mark"] = new Dictionary<string, object>
                    {
                        ["type"] = "rule",
                        ["color"] = "red",
                        ["strokeDash"] = new int[]{5,5}
                    },
                    ["encoding"] = new Dictionary<string, object>
                    {
                        ["y"] = new Dictionary<string, object>
                        {
                            ["aggregate"] = "mean",
                            ["field"] = "value",
                            ["type"] = "quantitative"
                        }
                    }
                }
            },

            ["selection"] = new Dictionary<string, object>
            {
                ["zoom"] = new Dictionary<string, object>
                {
                    ["type"] = "interval",
                    ["bind"] = "scales"
                }
            }
        };

        await JS.InvokeVoidAsync("renderVegaFromSpec", "lineMainChart", spec);
    }
}