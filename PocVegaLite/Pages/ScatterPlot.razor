@page "/scatterplot"
@inject IJSRuntime JS
@inject HttpClient Http
@using System.Text.Json

<div class="container">
    <h1>📊 Scatter Plot - Performance vs Cost</h1>
    <p class="subtitle">150 puntos cargados desde JSON</p>

    <div class="chart-card">
        <div id="scatterMainChart" class="chart-container"></div>
    </div>

    <div class="info-card">
        <h3>📈 Información</h3>
        <p>Total puntos: <strong>@dataPoints.Length</strong></p>
        <p>Categorías: <strong>@categories</strong></p>
        <p>X (Cost): <strong>@xRange</strong></p>
        <p>Y (Performance): <strong>@yRange</strong></p>
    </div>
</div>

<style>
    .container {
        padding: 30px;
        background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
        min-height: 100vh;
    }

    h1 {
        color: white;
        text-align: center;
        margin-bottom: 10px;
        font-size: 2.5em;
        text-shadow: 0 2px 4px rgba(0, 0, 0, 0.2);
    }

    .subtitle {
        text-align: center;
        color: rgba(255, 255, 255, 0.9);
        margin-bottom: 30px;
        font-size: 1.1em;
    }

    .chart-card {
        background: white;
        border-radius: 10px;
        padding: 20px;
        box-shadow: 0 8px 32px rgba(0, 0, 0, 0.1);
        margin-bottom: 20px;
        max-width: 1200px;
        margin-left: auto;
        margin-right: auto;
    }

    .chart-container {
        min-height: 600px;
        width: 100%;
    }

    .info-card {
        background: white;
        border-radius: 10px;
        padding: 20px;
        box-shadow: 0 8px 32px rgba(0, 0, 0, 0.1);
        max-width: 1200px;
        margin-left: auto;
        margin-right: auto;
    }

    .info-card h3 {
        margin-top: 0;
        color: #667eea;
    }

    .info-card p {
        margin: 10px 0;
        font-size: 1.05em;
    }

    strong {
        color: #764ba2;
        font-weight: 600;
    }

    @@media (max-width: 768px) {
        .container {
            padding: 15px;
        }

        h1 {
            font-size: 1.8em;
        }

        .chart-container {
            min-height: 400px;
        }
    }
</style>

@code {

    private class ScatterPlotRecord
    {
        public int Id { get; set; }
        public double X { get; set; }
        public double Y { get; set; }
        public string? Category { get; set; }
        public int Size { get; set; }
        public int Performance { get; set; }
    }

    private object[] dataPointsAnonymous = Array.Empty<object>();
    private ScatterPlotRecord[] dataPoints = Array.Empty<ScatterPlotRecord>();
    private bool dataLoaded = false;
    private string categories = "0";
    private string xRange = "N/A";
    private string yRange = "N/A";

    protected override async Task OnInitializedAsync()
    {
        await LoadDataFromJson();
        dataLoaded = true;
    }

    private async Task LoadDataFromJson()
    {
        try
        {
            var json = await Http.GetStringAsync("sample-data/scatterplot-data.json");
            var options = new JsonSerializerOptions { PropertyNameCaseInsensitive = true };
            var records = JsonSerializer.Deserialize<List<ScatterPlotRecord>>(json, options);

            if (records != null && records.Count > 0)
            {
                dataPoints = records.ToArray();
                dataPointsAnonymous = records.Select(r => new
                {
                    id = r.Id,
                    x = r.X,
                    y = r.Y,
                    category = r.Category,
                    size = r.Size,
                    performance = r.Performance
                }).Cast<object>().ToArray();

                // Calcular estadísticas
                var uniqueCategories = records.Select(r => r.Category).Distinct().Count();
                var minX = records.Min(r => r.X);
                var maxX = records.Max(r => r.X);
                var minY = records.Min(r => r.Y);
                var maxY = records.Max(r => r.Y);

                categories = uniqueCategories.ToString();
                xRange = $"{minX:F1} - {maxX:F1}";
                yRange = $"{minY:F1} - {maxY:F1}";

                Console.WriteLine($"ScatterPlot data loaded: {dataPoints.Length} records");
            }
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Error loading data: {ex.Message}");
        }
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (!dataLoaded || dataPointsAnonymous.Length == 0)
            return;

        var spec = new Dictionary<string, object>
        {
            ["$schema"] = "https://vega.github.io/schema/vega-lite/v5.json",
            ["width"] = 1000,
            ["height"] = 550,
            ["title"] = "Performance vs Cost Analysis",
            ["data"] = new Dictionary<string, object>
            {
                ["values"] = dataPointsAnonymous
            },
            ["mark"] = new { type = "circle", opacity = 0.6 },
            ["encoding"] = new Dictionary<string, object>
            {
                ["x"] = new { field = "x", type = "quantitative", title = "Cost Index" },
                ["y"] = new { field = "y", type = "quantitative", title = "Performance Score" },
                ["color"] = new { field = "category", type = "nominal" },
                ["size"] = new { field = "performance", type = "quantitative" }
            }
        };

        await JS.InvokeVoidAsync("renderVegaFromSpec", "scatterMainChart", spec);
    }
}