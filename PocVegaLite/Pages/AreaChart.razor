@page "/areachart"
@inject IJSRuntime JS
@inject HttpClient Http
@using System.Collections.Generic
@using System.Text.Json

<div class="area-container">

    <div class="header-section">
        <h1>📈 Area Chart</h1>
        <p class="subtitle">
            Interactive area with zoom, smoothed line, and data points
        </p>
    </div>

    <!-- Chart Card -->
    <div class="chart-card">
        <div class="chart-title">Revenue Trend</div>
        <div id="areaChart" class="chart-container"></div>
    </div>

    <!-- Stats -->
    <div class="stats-grid">
        <div class="stat-card">
            <div class="stat-label">Total Revenue</div>
            <div class="stat-value">$@totalRevenue K</div>
        </div>
        <div class="stat-card">
            <div class="stat-label">Total Costs</div>
            <div class="stat-value">$@totalCosts K</div>
        </div>
        <div class="stat-card">
            <div class="stat-label">Average Revenue</div>
            <div class="stat-value">$@averageRevenue K</div>
        </div>
        <div class="stat-card">
            <div class="stat-label">Average Costs</div>
            <div class="stat-value">$@averageCosts K</div>
        </div>
        <div class="stat-card">
            <div class="stat-label">Max Revenue</div>
            <div class="stat-value">$@maxRevenue K</div>
        </div>
        <div class="stat-card">
            <div class="stat-label">Profit Margin</div>
            <div class="stat-value">@profitMargin%</div>
        </div>
    </div>

</div>

<style>
    .area-container {
        background: linear-gradient(135deg, #e3f2fd, #ffffff);
        min-height: 100vh;
        padding: 40px 20px;
        font-family: 'Segoe UI', Tahoma, Verdana, sans-serif;
    }

    .header-section {
        text-align: center;
        margin-bottom: 40px;
    }

    .header-section h1 {
        font-size: 2.3em;
        font-weight: 700;
    }

    .subtitle {
        color: #555;
    }

    .chart-card {
        background: white;
        border-radius: 16px;
        padding: 30px;
        box-shadow: 0 20px 60px rgba(0, 0, 0, 0.15);
        max-width: 1100px;
        margin: 0 auto;
    }

    .chart-title {
        font-size: 1.3em;
        font-weight: 600;
        margin-bottom: 15px;
        border-bottom: 3px solid #2196F3;
        padding-bottom: 10px;
    }

    .chart-container {
        height: 400px;
    }

    .stats-grid {
        display: grid;
        grid-template-columns: repeat(auto-fit, minmax(200px, 1fr));
        gap: 20px;
        max-width: 1100px;
        margin: 40px auto;
    }

    .stat-card {
        background: white;
        padding: 20px;
        border-radius: 12px;
        text-align: center;
        box-shadow: 0 8px 20px rgba(0, 0, 0, 0.1);
    }

    .stat-label {
        color: #777;
        font-size: .9em;
    }

    .stat-value {
        font-size: 1.8em;
        font-weight: 700;
        color: #2196F3;
    }
</style>

@code {

    private class SalesRecord
    {
        public string? Month { get; set; }
        public double Revenue { get; set; }
        public double Costs { get; set; }
    }

    private Dictionary<string, object>[] salesData = Array.Empty<Dictionary<string, object>>();

    private double totalRevenue;
    private double totalCosts;
    private double averageRevenue;
    private double averageCosts;
    private double maxRevenue;
    private double profitMargin;

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (!firstRender) return;

        await GenerateDataFromJson();
        ComputeStats();

        StateHasChanged();

        await RenderAreaChart();
    }

    private async Task GenerateDataFromJson()
    {
        try
        {
            var json = await Http.GetStringAsync("sample-data/sales-data.json");
            var options = new JsonSerializerOptions { PropertyNameCaseInsensitive = true };
            var records = JsonSerializer.Deserialize<List<SalesRecord>>(json, options);

            if (records != null && records.Count > 0)
            {
                salesData = records.Select(r => new Dictionary<string, object>
                {
                    { "month", r.Month ?? "" },
                    { "revenue", r.Revenue },
                    { "costs", r.Costs }
                }).ToArray();
                Console.WriteLine($"Data loaded successfully: {salesData.Length} records");
            }
            else
            {
                Console.WriteLine("No records found in JSON");
                salesData = Array.Empty<Dictionary<string, object>>();
            }
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Error loading JSON data: {ex.Message}");
            Console.WriteLine($"Stack trace: {ex.StackTrace}");
            salesData = Array.Empty<Dictionary<string, object>>();
        }
    }

    private void ComputeStats()
    {
        if (salesData.Length == 0) return;

        var revenueValues = salesData.Select(d => Convert.ToDouble(d["revenue"])).ToList();
        var costValues = salesData.Select(d => Convert.ToDouble(d["costs"])).ToList();

        totalRevenue = revenueValues.Sum();
        totalCosts = costValues.Sum();
        averageRevenue = Math.Round(revenueValues.Average(), 2);
        averageCosts = Math.Round(costValues.Average(), 2);
        maxRevenue = revenueValues.Max();

        var profit = totalRevenue - totalCosts;
        profitMargin = Math.Round((profit / totalRevenue) * 100, 2);
    }

    private async Task RenderAreaChart()
    {
        // Crear líneas de referencia con colores por rango
        var referenceLines = new List<Dictionary<string, object>>
        {
            new Dictionary<string, object> { { "value", 100 }, { "color", "#e74c3c" } }, // Rojo 100
            new Dictionary<string, object> { { "value", 150 }, { "color", "#f39c12" } }, // Naranja 150
            new Dictionary<string, object> { { "value", 200 }, { "color", "#2ecc71" } }, // Verde 200
            new Dictionary<string, object> { { "value", 250 }, { "color", "#3498db" } } // Azul 250
        };

        var spec = new Dictionary<string, object>
        {
            ["$schema"] = "https://vega.github.io/schema/vega-lite/v5.json",
            ["width"] = 900,
            ["height"] = 400,

            ["data"] = new Dictionary<string, object>
            {
                ["values"] = salesData
            },

            ["selection"] = new Dictionary<string, object>
            {
                ["zoom"] = new Dictionary<string, object>
                {
                    ["type"] = "interval",
                    ["bind"] = "scales"
                }
            },

            ["layer"] = new object[]
            {
                // Capa 0: Líneas de referencia de grid
                new Dictionary<string, object>
                {
                    ["data"] = new Dictionary<string, object> { ["values"] = referenceLines },
                    ["mark"] = new Dictionary<string, object>
                    {
                        ["type"] = "rule",
                        ["size"] = 2,
                        ["opacity"] = 0.6
                    },
                    ["encoding"] = new Dictionary<string, object>
                    {
                        ["y"] = new Dictionary<string, object>
                        {
                            ["field"] = "value",
                            ["type"] = "quantitative"
                        },
                        ["color"] = new Dictionary<string, object>
                        {
                            ["field"] = "color",
                            ["type"] = "nominal",
                            ["scale"] = new Dictionary<string, object>
                            {
                                ["domain"] = new[] { "#e74c3c", "#f39c12", "#2ecc71", "#3498db" },
                                ["range"] = new[] { "#e74c3c", "#f39c12", "#2ecc71", "#3498db" }
                            },
                            ["legend"] = null
                        }
                    }
                },
                new Dictionary<string, object>
                {
                    ["mark"] = new Dictionary<string, object>
                    {
                        ["type"] = "area",
                        ["interpolate"] = "monotone",
                        ["opacity"] = 0.6,
                        ["line"] = new Dictionary<string, object>
                        {
                            ["color"] = "#2196F3",
                            ["strokeWidth"] = 3
                        },
                        ["point"] = new Dictionary<string, object>
                        {
                            ["filled"] = true,
                            ["size"] = 60,
                            ["color"] = "#1976D2"
                        }
                    },

                    ["encoding"] = new Dictionary<string, object>
                    {
                        ["x"] = new Dictionary<string, object>
                        {
                            ["field"] = "month",
                            ["type"] = "ordinal",
                            ["title"] = "Month",
                            ["sort"] = new[] { "Jan", "Feb", "Mar", "Apr", "May", "Jun" }
                        },

                        ["y"] = new Dictionary<string, object>
                        {
                            ["field"] = "revenue",
                            ["type"] = "quantitative",
                            ["title"] = "Amount ($K)"
                        },

                        ["color"] = new Dictionary<string, object>
                        {
                            ["value"] = "#64B5F6"
                        },

                        ["tooltip"] = new object[]
                        {
                            new Dictionary<string, object>
                            {
                                ["field"] = "month",
                                ["type"] = "ordinal",
                                ["title"] = "Month"
                            },
                            new Dictionary<string, object>
                            {
                                ["field"] = "revenue",
                                ["type"] = "quantitative",
                                ["title"] = "Revenue ($K)"
                            }
                        }
                    }
                },

                // Capa 2: Área de Costs
                new Dictionary<string, object>
                {
                    ["mark"] = new Dictionary<string, object>
                    {
                        ["type"] = "area",
                        ["interpolate"] = "monotone",
                        ["opacity"] = 0.5,
                        ["line"] = new Dictionary<string, object>
                        {
                            ["color"] = "#FF6F00",
                            ["strokeWidth"] = 3
                        },
                        ["point"] = new Dictionary<string, object>
                        {
                            ["filled"] = true,
                            ["size"] = 50,
                            ["color"] = "#E65100"
                        }
                    },

                    ["encoding"] = new Dictionary<string, object>
                    {
                        ["x"] = new Dictionary<string, object>
                        {
                            ["field"] = "month",
                            ["type"] = "ordinal",
                            ["sort"] = new[] { "Jan", "Feb", "Mar", "Apr", "May", "Jun" }
                        },

                        ["y"] = new Dictionary<string, object>
                        {
                            ["field"] = "costs",
                            ["type"] = "quantitative"
                        },

                        ["color"] = new Dictionary<string, object>
                        {
                            ["value"] = "#FFB74D"
                        },

                        ["tooltip"] = new object[]
                        {
                            new Dictionary<string, object>
                            {
                                ["field"] = "month",
                                ["type"] = "ordinal",
                                ["title"] = "Month"
                            },
                            new Dictionary<string, object>
                            {
                                ["field"] = "costs",
                                ["type"] = "quantitative",
                                ["title"] = "Costs ($K)"
                            }
                        }
                    }
                }
            },

            ["config"] = new Dictionary<string, object>
            {
                ["axis"] = new Dictionary<string, object>
                {
                    ["gridColor"] = "#d0d0d0",
                    ["gridOpacity"] = 0.5,
                    ["gridDash"] = new int[] { 3, 3 }
                },
                ["mark"] = new Dictionary<string, object>
                {
                    ["opacity"] = 0.8
                }
            }
        };

        await JS.InvokeVoidAsync("renderVegaFromSpec", "areaChart", spec);
    }
}