@page "/"
@inject Services.StatisticsService StatisticsService
@inject NavigationManager Navigation

<PageTitle>Dashboard - Radzen POC</PageTitle>

<RadzenStack Gap="1rem">
    <RadzenRow>
        <RadzenColumn>
            <RadzenText TextStyle="TextStyle.H3" TagName="TagName.H1">
                <RadzenIcon Icon="dashboard" /> Dashboard
            </RadzenText>
            <RadzenText TextStyle="TextStyle.Subtitle2" class="rz-color-secondary">Control panel and statistics</RadzenText>
        </RadzenColumn>
    </RadzenRow>

    <!-- Statistics Cards -->
    <RadzenRow Gap="1rem">
        <!-- Total Products -->
        <RadzenColumn Size="12" SizeSM="6" SizeLG="3">
            <RadzenCard>
                <RadzenStack Orientation="Orientation.Horizontal" JustifyContent="JustifyContent.SpaceBetween" AlignItems="AlignItems.Start" Gap="1rem">
                    <RadzenStack Gap="0.5rem">
                        <RadzenText TextStyle="TextStyle.Overline" class="rz-color-secondary">Total Products</RadzenText>
                        <RadzenText TextStyle="TextStyle.H4" TagName="TagName.H2" class="rz-color-primary">@StatisticsService.GetTotalProducts()</RadzenText>
                    </RadzenStack>
                    <RadzenIcon Icon="inventory_2" style="font-size: 3rem;" class="rz-color-primary-light" />
                </RadzenStack>
                <RadzenText TextStyle="TextStyle.Caption" class="rz-color-secondary rz-mt-3">
                    <RadzenIcon Icon="info" /> In catalog
                </RadzenText>
            </RadzenCard>
        </RadzenColumn>

        <!-- Total Inventory Value -->
        <RadzenColumn Size="12" SizeSM="6" SizeLG="3">
            <RadzenCard>
                <RadzenStack Orientation="Orientation.Horizontal" JustifyContent="JustifyContent.SpaceBetween" AlignItems="AlignItems.Start" Gap="1rem">
                    <RadzenStack Gap="0.5rem">
                        <RadzenText TextStyle="TextStyle.Overline" class="rz-color-secondary">Inventory Value</RadzenText>
                        <RadzenText TextStyle="TextStyle.H4" TagName="TagName.H2" class="rz-color-success">$@StatisticsService.GetTotalInventoryValue().ToString("N2")</RadzenText>
                    </RadzenStack>
                    <RadzenIcon Icon="attach_money" style="font-size: 3rem;" class="rz-color-success-light" />
                </RadzenStack>
                <RadzenText TextStyle="TextStyle.Caption" class="rz-color-secondary rz-mt-3">
                    <RadzenIcon Icon="info" /> Price × Stock
                </RadzenText>
            </RadzenCard>
        </RadzenColumn>

        <!-- Low Stock Products -->
        <RadzenColumn Size="12" SizeSM="6" SizeLG="3">
            <RadzenCard>
                <RadzenStack Orientation="Orientation.Horizontal" JustifyContent="JustifyContent.SpaceBetween" AlignItems="AlignItems.Start" Gap="1rem">
                    <RadzenStack Gap="0.5rem">
                        <RadzenText TextStyle="TextStyle.Overline" class="rz-color-secondary">Low Stock</RadzenText>
                        <RadzenText TextStyle="TextStyle.H4" TagName="TagName.H2" class="rz-color-warning">@StatisticsService.GetLowStockProducts()</RadzenText>
                    </RadzenStack>
                    <RadzenIcon Icon="warning" style="font-size: 3rem;" class="rz-color-warning-light" />
                </RadzenStack>
                <RadzenText TextStyle="TextStyle.Caption" class="rz-color-secondary rz-mt-3">
                    <RadzenIcon Icon="info" /> Less than 20 units
                </RadzenText>
            </RadzenCard>
        </RadzenColumn>

        <!-- Pending Tasks -->
        <RadzenColumn Size="12" SizeSM="6" SizeLG="3">
            <RadzenCard>
                <RadzenStack Orientation="Orientation.Horizontal" JustifyContent="JustifyContent.SpaceBetween" AlignItems="AlignItems.Start" Gap="1rem">
                    <RadzenStack Gap="0.5rem">
                        <RadzenText TextStyle="TextStyle.Overline" class="rz-color-secondary">Pending Tasks</RadzenText>
                        <RadzenText TextStyle="TextStyle.H4" TagName="TagName.H2" class="rz-color-danger">@StatisticsService.GetPendingTasks()</RadzenText>
                    </RadzenStack>
                    <RadzenIcon Icon="task_alt" style="font-size: 3rem;" class="rz-color-danger-light" />
                </RadzenStack>
                <RadzenText TextStyle="TextStyle.Caption" class="rz-color-secondary rz-mt-3">
                    <RadzenIcon Icon="info" /> To complete
                </RadzenText>
            </RadzenCard>
        </RadzenColumn>
    </RadzenRow>

    <!-- Products by Category and Tasks by Status -->
    <RadzenRow Gap="1rem">
        <!-- Products by Category -->
        <RadzenColumn Size="12" SizeLG="6">
            <RadzenCard>
                <RadzenText TextStyle="TextStyle.H5" class="rz-mb-4">
                    <RadzenIcon Icon="category" /> Products by Category
                </RadzenText>
                @{
                    var productsByCategory = StatisticsService.GetProductsByCategory();
                    var totalProducts = productsByCategory.Values.Sum();
                }
                @foreach (var category in productsByCategory.OrderByDescending(x => x.Value))
                {
                    var percentage = totalProducts > 0 ? (category.Value * 100.0 / totalProducts) : 0;
                    <RadzenStack Gap="0.5rem" class="rz-mb-3">
                        <RadzenStack Orientation="Orientation.Horizontal" JustifyContent="JustifyContent.SpaceBetween">
                            <RadzenText TextStyle="TextStyle.Subtitle2">@category.Key</RadzenText>
                            <RadzenText TextStyle="TextStyle.Caption" class="rz-color-secondary">@category.Value products (@percentage.ToString("F1")%)</RadzenText>
                        </RadzenStack>
                        <RadzenProgressBar Value="@percentage" Max="100" ShowValue="false" />
                    </RadzenStack>
                }
            </RadzenCard>
        </RadzenColumn>

        <!-- Tasks by Status -->
        <RadzenColumn Size="12" SizeLG="6">
            <RadzenCard>
                <RadzenText TextStyle="TextStyle.H5" class="rz-mb-4">
                    <RadzenIcon Icon="checklist" /> Tasks by Status
                </RadzenText>
                @{
                    var tasksByStatus = StatisticsService.GetTasksByStatus();
                    var totalTasks = tasksByStatus.Values.Sum();
                }
                @foreach (var status in tasksByStatus)
                {
                    var percentage = totalTasks > 0 ? (status.Value * 100.0 / totalTasks) : 0;
                    var statusName = status.Key switch
                    {
                        Models.TaskStatus.Pending => "Pending",
                        Models.TaskStatus.InProgress => "In Progress",
                        Models.TaskStatus.Completed => "Completed",
                        _ => status.Key.ToString()
                    };
                    var variant = status.Key switch
                    {
                        Models.TaskStatus.Pending => Variant.Outlined,
                        Models.TaskStatus.InProgress => Variant.Outlined,
                        Models.TaskStatus.Completed => Variant.Flat,
                        _ => Variant.Outlined
                    };
                    <RadzenStack Gap="0.5rem" class="rz-mb-3">
                        <RadzenStack Orientation="Orientation.Horizontal" JustifyContent="JustifyContent.SpaceBetween">
                            <RadzenText TextStyle="TextStyle.Subtitle2">@statusName</RadzenText>
                            <RadzenText TextStyle="TextStyle.Caption" class="rz-color-secondary">@status.Value tasks (@percentage.ToString("F1")%)</RadzenText>
                        </RadzenStack>
                        <RadzenProgressBar Value="@percentage" Max="100" ShowValue="false" Variant="@variant" />
                    </RadzenStack>
                }
            </RadzenCard>
        </RadzenColumn>
    </RadzenRow>

    <!-- Pending Tasks by Priority -->
    <RadzenRow>
        <RadzenColumn>
            <RadzenCard>
                <RadzenText TextStyle="TextStyle.H5" class="rz-mb-4">
                    <RadzenIcon Icon="flag" /> Pending Tasks by Priority
                </RadzenText>
                <RadzenRow Gap="1rem">
                    @{
                        var tasksByPriority = StatisticsService.GetTasksByPriority();
                    }
                    @foreach (var priority in tasksByPriority)
                    {
                        var priorityName = priority.Key switch
                        {
                            Models.TaskPriority.Low => "Low",
                            Models.TaskPriority.Medium => "Medium",
                            Models.TaskPriority.High => "High",
                            _ => priority.Key.ToString()
                        };
                        var icon = priority.Key switch
                        {
                            Models.TaskPriority.Low => "arrow_downward",
                            Models.TaskPriority.Medium => "remove",
                            Models.TaskPriority.High => "arrow_upward",
                            _ => "remove"
                        };
                        var colorClass = priority.Key switch
                        {
                            Models.TaskPriority.Low => "rz-color-success",
                            Models.TaskPriority.Medium => "rz-color-warning",
                            Models.TaskPriority.High => "rz-color-danger",
                            _ => "rz-color-secondary"
                        };
                        <RadzenColumn Size="12" SizeMD="4">
                            <RadzenCard class="rz-text-align-center">
                                <RadzenIcon Icon="@icon" style="font-size: 3rem;" class="@colorClass" />
                                <RadzenText TextStyle="TextStyle.H3" class="@($"{colorClass} rz-mt-2")">@priority.Value</RadzenText>
                                <RadzenText TextStyle="TextStyle.Caption" class="rz-color-secondary">@priorityName Priority</RadzenText>
                            </RadzenCard>
                        </RadzenColumn>
                    }
                </RadzenRow>
            </RadzenCard>
        </RadzenColumn>
    </RadzenRow>

    <!-- Quick Actions -->
    <RadzenRow>
        <RadzenColumn>
            <RadzenCard>
                <RadzenText TextStyle="TextStyle.H5" class="rz-mb-4">
                    <RadzenIcon Icon="bolt" /> Quick Actions
                </RadzenText>
                <RadzenRow Gap="1rem">
                    <RadzenColumn Size="12" SizeMD="4">
                        <RadzenButton Click="NavigateToProducts" ButtonStyle="ButtonStyle.Primary" Size="ButtonSize.Large" class="rz-border-radius-3" Style="width: 100%; height: 120px;">
                            <RadzenStack AlignItems="AlignItems.Center" Gap="0.5rem">
                                <RadzenIcon Icon="inventory_2" style="font-size: 2.5rem;" />
                                <span>View Products</span>
                            </RadzenStack>
                        </RadzenButton>
                    </RadzenColumn>
                    <RadzenColumn Size="12" SizeMD="4">
                        <RadzenButton Click="NavigateToTasks" ButtonStyle="ButtonStyle.Success" Size="ButtonSize.Large" class="rz-border-radius-3" Style="width: 100%; height: 120px;">
                            <RadzenStack AlignItems="AlignItems.Center" Gap="0.5rem">
                                <RadzenIcon Icon="task_alt" style="font-size: 2.5rem;" />
                                <span>View Tasks</span>
                            </RadzenStack>
                        </RadzenButton>
                    </RadzenColumn>
                    <RadzenColumn Size="12" SizeMD="4">
                        <RadzenButton Click="NavigateToComponents" ButtonStyle="ButtonStyle.Info" Size="ButtonSize.Large" class="rz-border-radius-3" Style="width: 100%; height: 120px;">
                            <RadzenStack AlignItems="AlignItems.Center" Gap="0.5rem">
                                <RadzenIcon Icon="widgets" style="font-size: 2.5rem;" />
                                <span>View Components</span>
                            </RadzenStack>
                        </RadzenButton>
                    </RadzenColumn>
                </RadzenRow>
            </RadzenCard>
        </RadzenColumn>
    </RadzenRow>
</RadzenStack>

@code {
    private void NavigateToProducts()
    {
        Navigation.NavigateTo("/products");
    }

    private void NavigateToTasks()
    {
        Navigation.NavigateTo("/tasks");
    }

    private void NavigateToComponents()
    {
        Navigation.NavigateTo("/components");
    }
}
