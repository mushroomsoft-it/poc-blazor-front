@page "/mean"
@using Syncfusion.Blazor.Charts
@inject HttpClient Http

<div class="meanchart-container">
    <h2>QC Control Chart - Mean ± Standard Deviations</h2>
    <p style="text-align: center; color: #666; margin-bottom: 20px;">
        Quality monitoring: detect trends and out-of-control points
    </p>

    <SfChart Title="Control Chart: Mean ± SD" Width="100%" Height="550px">

        <!-- Tooltip -->
        <ChartTooltipSettings Enable="true" Format="<b>Day:</b> ${point.x}<br/><b>Value:</b> ${point.y}" Shared="false">
        </ChartTooltipSettings>

        <!-- Legend -->
        <ChartLegendSettings Visible="true" Position="LegendPosition.Top" Background="white">
        </ChartLegendSettings>

        <ChartPrimaryXAxis ValueType="Syncfusion.Blazor.Charts.ValueType.Category" Title="Measurement Date"
                           LabelFormat="{value}">
            <ChartAxisMajorGridLines Width="0"></ChartAxisMajorGridLines>
        </ChartPrimaryXAxis>

        <ChartPrimaryYAxis Title="Measured Value" LabelFormat="N0" Minimum="@YAxisMin" Maximum="@YAxisMax">

            <ChartAxisMajorGridLines Width="2" Color="#E8E8E8" DashArray="3,2"></ChartAxisMajorGridLines>

            <ChartStriplines>

                <!-- ±3SD (Más bajo) -->
                <ChartStripline Start="@SD3Minus" Size="0" Color="#0D47A1" DashArray="6,4"
                                Text="@($"-3SD = {SD3Minus:F2}")" HorizontalAlignment="Syncfusion.Blazor.Charts.Anchor.End" />

                <!-- ±2SD -->
                <ChartStripline Start="@SD2Minus" Size="0" Color="#1976D2" DashArray="4,4"
                                Text="@($"-2SD = {SD2Minus:F2}")" HorizontalAlignment="Syncfusion.Blazor.Charts.Anchor.End" />

                <!-- ±1SD -->
                <ChartStripline Start="@SD1Minus" Size="0" Color="#4CAF50" DashArray="4,4"
                                Text="@($"-1SD = {SD1Minus:F2}")" HorizontalAlignment="Syncfusion.Blazor.Charts.Anchor.End" />

                <!-- Mean -->
                <ChartStripline Start="@Mean" Size="0" Color="#FBC02D" DashArray="6,4" Text="@($"Mean = {Mean:F2}")"
                                HorizontalAlignment="Syncfusion.Blazor.Charts.Anchor.End"
                                VerticalAlignment="Syncfusion.Blazor.Charts.Anchor.Middle">
                </ChartStripline>

                <!-- ±1SD -->
                <ChartStripline Start="@SD1Plus" Size="0" Color="#FF9800" DashArray="4,4"
                                Text="@($"+1SD = {SD1Plus:F2}")" HorizontalAlignment="Syncfusion.Blazor.Charts.Anchor.End" />

                <!-- ±2SD -->
                <ChartStripline Start="@SD2Plus" Size="0" Color="#E64A19" DashArray="4,4"
                                Text="@($"+2SD = {SD2Plus:F2}")" HorizontalAlignment="Syncfusion.Blazor.Charts.Anchor.End" />

                <!-- ±3SD (Más alto) -->
                <ChartStripline Start="@SD3Plus" Size="0" Color="#C62828" DashArray="6,4"
                                Text="@($"+3SD = {SD3Plus:F2}")" HorizontalAlignment="Syncfusion.Blazor.Charts.Anchor.End" />

            </ChartStriplines>

        </ChartPrimaryYAxis>

        <ChartSeriesCollection>

            <!-- Baseline (Control) -->
            <ChartSeries DataSource="@AllPoints" Name="Normal Measurements" XName="Date" YName="Value"
                         Type="ChartSeriesType.Line" Width="2" Fill="#2196F3">
                <ChartMarker Visible="true" Width="8" Height="8" Fill="#2196F3"></ChartMarker>
            </ChartSeries>

            <!-- Warnings ±2SD -->
            <ChartSeries DataSource="@WarningPoints" Name="Warnings (±2SD)" XName="Date" YName="Value"
                         Type="ChartSeriesType.Scatter" Fill="#FF9800">
                <ChartMarker Visible="true" Width="12" Height="12" Fill="#FF9800"></ChartMarker>
            </ChartSeries>

            <!-- Critical ±3SD -->
            <ChartSeries DataSource="@CriticalPoints" Name="Critical (±3SD)" XName="Date" YName="Value"
                         Type="ChartSeriesType.Scatter" Fill="#F44336">
                <ChartMarker Visible="true" Width="14" Height="14" Fill="#F44336"></ChartMarker>
            </ChartSeries>

        </ChartSeriesCollection>

    </SfChart>

    <!-- QC Chart Information -->
    <div
        style="margin-top: 20px; padding: 20px; background-color: #f9f9f9; border-radius: 5px; border-left: 4px solid #2196F3;">
        <h4>📐 QC Chart Interpretation</h4>
        <ul style="margin: 10px 0; line-height: 1.8; padding-left: 20px;">
            <li><strong style="color: #2196F3;">● Blue Points:</strong> Measurements within control (≈ ±1.96σ)</li>
            <li><strong style="color: #FF9800;">● Orange Points:</strong> Warnings - Between ±2σ and ±3σ (Review
                process)</li>
                <li><strong style="color: #F44336;">● Red Points:</strong> Critical - Outside ±3σ (Stop and correct)</li>
                <li><strong style="color: #0D47A1;">— Darkest Blue Line:</strong> -3SD (Lowest values)</li>
                <li><strong style="color: #1976d2;">— Blue Line:</strong> -2SD</li>
                <li><strong style="color: #4caf50;">— Green Line:</strong> -1SD</li>
                <li><strong style="color: #FBC02D;">— Yellow Line:</strong> Mean (Center)</li>
                <li><strong style="color: #ff9800;">— Orange Line:</strong> +1SD</li>
                <li><strong style="color: #E64A19;">— Dark Orange Line:</strong> +2SD</li>
                <li><strong style="color: #c62828;">— Dark Red Line:</strong> +3SD (Highest values)</li>
            </ul>
        </div>

        <!-- Statistics -->
        <div
            style="margin-top: 15px; padding: 20px; background-color: #f0f7ff; border-radius: 5px; border-left: 4px solid #1976d2;">
            <h4>📈 Control Statistics</h4>
            <div style="display: grid; grid-template-columns: 1fr 1fr 1fr; gap: 15px;">
                <div style="background: white; padding: 15px; border-radius: 4px; text-align: center;">
                    <p style="margin: 0; color: #666; font-size: 0.9em;"><strong>Mean (μ)</strong></p>
                    <p style="margin: 5px 0; font-size: 1.4em; color: #2196F3; font-weight: bold;">@Mean.ToString("F2")</p>
                </div>
                <div style="background: white; padding: 15px; border-radius: 4px; text-align: center;">
                    <p style="margin: 0; color: #666; font-size: 0.9em;"><strong>Std Dev (σ)</strong></p>
                    <p style="margin: 5px 0; font-size: 1.4em; color: #4caf50; font-weight: bold;">@SD.ToString("F2")</p>
                </div>
                <div style="background: white; padding: 15px; border-radius: 4px; text-align: center;">
                    <p style="margin: 0; color: #666; font-size: 0.9em;"><strong>Total Measurements</strong></p>
                    <p style="margin: 5px 0; font-size: 1.4em; color: #555; font-weight: bold;">@AllPoints.Count</p>
                </div>
            </div>
            <div style="display: grid; grid-template-columns: 1fr 1fr 1fr; gap: 15px; margin-top: 15px;">
                <div style="background: #e3f2fd; padding: 12px; border-radius: 4px; text-align: center;">
                    <p style="margin: 0; color: #1976d2; font-size: 0.9em;"><strong>Normal</strong></p>
                    <p style="margin: 5px 0; font-size: 1.3em; color: #2196F3; font-weight: bold;">@(AllPoints.Count -
                                                                                                                                                                                                                                                                                                                                    WarningPoints.Count - CriticalPoints.Count)</p>
                    </div>
                    <div style="background: #fff3e0; padding: 12px; border-radius: 4px; text-align: center;">
                        <p style="margin: 0; color: #e65100; font-size: 0.9em;"><strong>Warnings</strong></p>
                        <p style="margin: 5px 0; font-size: 1.3em; color: #FF9800; font-weight: bold;">@WarningPoints.Count</p>
                    </div>
                    <div style="background: #ffebee; padding: 12px; border-radius: 4px; text-align: center;">
                        <p style="margin: 0; color: #b71c1c; font-size: 0.9em;"><strong>Critical</strong></p>
                        <p style="margin: 5px 0; font-size: 1.3em; color: #F44336; font-weight: bold;">@CriticalPoints.Count</p>
                    </div>
                </div>
            </div>
        </div>

        <style>
            .meanchart-container {
                padding: 20px;
                background: linear-gradient(135deg, #e3f2fd 0%, #f0f4f8 100%);
                border-radius: 8px;
                box-shadow: 0 4px 6px rgba(0, 0, 0, 0.1);
            }

            .meanchart-container h2 {
                color: #1565c0;
                margin-bottom: 10px;
                text-align: center;
            }

            .meanchart-container h4 {
                color: #333;
                margin-top: 0;
                margin-bottom: 12px;
            }

            .meanchart-container ul {
                margin: 0;
            }

            .meanchart-container li {
                margin: 8px 0;
            }

            .meanchart-container p {
                margin: 8px 0;
            }
        </style>

@code {

    public List<DataPoint> AllPoints = new();
    public List<DataPoint> WarningPoints = new();
    public List<DataPoint> CriticalPoints = new();

    public double Mean;
    public double SD;

    public double SD1Plus, SD1Minus;
    public double SD2Plus, SD2Minus;
    public double SD3Plus, SD3Minus;

    public double YAxisMin;
    public double YAxisMax;

    protected override async Task OnInitializedAsync()
    {
        await LoadDataFromJson();
        CalculateStatistics();
        ClassifyPoints();
    }

    private async Task LoadDataFromJson()
    {
        try
        {
            var json = await Http.GetStringAsync("sample-data/mean-chart-data.json");
            var options = new System.Text.Json.JsonSerializerOptions { PropertyNameCaseInsensitive = true };

            var data = System.Text.Json.JsonSerializer.Deserialize<MeanChartJsonData>(json, options);

            if (data?.AllPoints != null)
            {
                AllPoints = data.AllPoints;
            }

            Console.WriteLine($"Mean chart data loaded: {AllPoints.Count} points");
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Error loading mean chart data: {ex.Message}");
        }
    }

    private void CalculateStatistics()
    {
        if (AllPoints.Count == 0) return;

        Mean = AllPoints.Average(x => x.Value);

        double variance = AllPoints.Average(x =>
            Math.Pow(x.Value - Mean, 2));

        SD = Math.Sqrt(variance);

        SD1Plus = Mean + SD;
        SD1Minus = Mean - SD;

        SD2Plus = Mean + 2 * SD;
        SD2Minus = Mean - 2 * SD;

        SD3Plus = Mean + 3 * SD;
        SD3Minus = Mean - 3 * SD;

        YAxisMin = Math.Floor(Mean - 4 * SD);
        YAxisMax = Math.Ceiling(Mean + 4 * SD);
    }

    private void ClassifyPoints()
    {
        foreach (var point in AllPoints)
        {
            if (point.Value > SD3Plus || point.Value < SD3Minus)
                CriticalPoints.Add(point);
            else if (point.Value > SD2Plus || point.Value < SD2Minus)
                WarningPoints.Add(point);
        }
    }

    public class DataPoint
    {
        public string Date { get; set; } = "";
        public double Value { get; set; }
    }

    public class MeanChartJsonData
    {
        public List<DataPoint> AllPoints { get; set; } = new();
    }
}