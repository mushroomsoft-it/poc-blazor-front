@page "/histogram"
@inject IJSRuntime JS

<h3 class="mb-4">Histogram + Normal Curve</h3>

<div class="container">
    <canvas id="histChart" width="900" height="450"></canvas>
</div>

@code {

    private List<double> Values = new();
    private bool _chartRendered = false;

    protected override void OnInitialized()
    {
        var random = new Random();

        // Generamos datos tipo laboratorio
        for (int i = 0; i < 100; i++)
        {
            Values.Add(100 + (random.NextDouble() * 40 - 20));
        }
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender && !_chartRendered)
        {
            _chartRendered = true;
            await RenderChart();
        }
    }

    private async Task RenderChart()
    {
        await JS.InvokeVoidAsync("createHistogramWithNormal", "histChart", Values);
    }
}