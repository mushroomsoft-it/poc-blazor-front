@page "/histogram"
@inject TeeChartService TeeChartService

<h3 class="mb-4">Histogram + Normal Curve - Enterprise</h3>

<div class="container">
    <canvas id="histChart" width="1000" height="450"></canvas>
</div>

<div class="mt-3">
    <button class="btn btn-primary me-2" @onclick="Actualizar">
        Generate New Data
    </button>

    <button class="btn btn-outline-secondary" @onclick="GenerarMuchosDatos">
        Generate 10,000 Data Points
    </button>
</div>

@code {

    private List<double> Values = new();

    protected override void OnInitialized()
    {
        GenerarDatos(200);
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            await TeeChartService.InitializeAsync();

            await TeeChartService.CreateChartAsync(
                "histogram",
                "histChart",
                Values,
                new
                {
                    title = "Histograma + Curva Normal",
                    bins = 12
                });
        }
    }

    private void GenerarDatos(int cantidad)
    {
        var random = new Random();
        Values.Clear();

        for (int i = 0; i < cantidad; i++)
        {
            // Distribución simulada centrada en 100
            Values.Add(100 + (random.NextDouble() * 30 - 15));
        }
    }

    private async Task Actualizar()
    {
        GenerarDatos(200);

        await TeeChartService.UpdateChartAsync(
            "histogram",
            "histChart",
            Values,
            new
            {
                bins = 12
            });
    }

    private async Task GenerarMuchosDatos()
    {
        GenerarDatos(10000);

        await TeeChartService.UpdateChartAsync(
            "histogram",
            "histChart",
            Values,
            new
            {
                bins = 12
            });
    }
}