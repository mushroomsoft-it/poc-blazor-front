@page "/controlchart"
@inject TeeChartService TeeChartService

<h3 class="mb-4">Control Chart - Mean and Limits</h3>

<div class="container">
    <canvas id="controlChart" width="1000" height="450"></canvas>
</div>

<div class="mt-3">
    <button class="btn btn-primary me-2" @onclick="Actualizar">
        Generate New Data
    </button>

    <button class="btn btn-outline-secondary" @onclick="GenerarMuchosDatos">
        Generate 10,000 Data Points
    </button>
</div>

@code {

    private List<double> Values = new();

    protected override void OnInitialized()
    {
        GenerarDatos(50);
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            await TeeChartService.InitializeAsync();

            await TeeChartService.CreateChartAsync(
                "mean",
                "controlChart",
                Values,
                new
                {
                    title = "Control Chart",
                });
        }
    }

    private void GenerarDatos(int cantidad)
    {
        var random = new Random();
        Values.Clear();

        for (int i = 0; i < cantidad; i++)
        {
            Values.Add(100 + (random.NextDouble() * 10 - 5));
        }
    }

    private async Task Actualizar()
    {
        GenerarDatos(50);

        await TeeChartService.UpdateChartAsync(
            "mean",
            "controlChart",
            Values,
            new { }
        );
    }

    private async Task GenerarMuchosDatos()
    {
        GenerarDatos(10000);

        await TeeChartService.UpdateChartAsync(
            "mean",
            "controlChart",
            Values,
            new { }
        );
    }
}