@typeparam TItem

@code {
    [CascadingParameter] public DataGrid<TItem>? ParentGrid { get; set; }

    [Parameter] public string PropertyName { get; set; } = string.Empty;
    [Parameter] public string? Title { get; set; }
    [Parameter] public string? Width { get; set; }
    [Parameter] public bool Sortable { get; set; } = true;
    [Parameter] public bool Filterable { get; set; } = true;
    [Parameter] public RenderFragment<TItem>? Template { get; set; }
    [Parameter] public string? Format { get; set; }
    [Parameter] public TextAlignment Alignment { get; set; } = TextAlignment.Left;
    [Parameter] public List<string>? FilterOptions { get; set; }

    protected override void OnInitialized()
    {
        ParentGrid?.AddColumn(this);
    }

    internal Columns.GridColumnDefinition<TItem> ToColumnDefinition()
    {
        return new Columns.GridColumnDefinition<TItem>
        {
            PropertyName = PropertyName,
            Title = Title,
            Width = Width,
            Sortable = Sortable,
            Filterable = Filterable,
            Template = Template,
            Format = Format,
            Alignment = Alignment,
            FilterOptions = FilterOptions
        };
    }
}
