@using Bootstrap_POC.Components.DataGrid.Filters
@using Bootstrap_POC.Components.DataGrid.Extensions

@* Backdrop - rendered at body level via portal pattern *@
@if (_isPanelOpen)
{
    <div class="filter-panel-backdrop" @onclick="ClosePanel" @onclick:stopPropagation="true"></div>
}

<div class="filter-panel-container">
    <!-- Filter Button -->
    <button class="btn @(ActiveFilterCount > 0 ? "btn-primary" : "btn-outline-secondary") d-flex align-items-center gap-2"
            type="button"
            id="@_buttonId"
            @onclick="TogglePanel"
            @onclick:stopPropagation="true">
        <i class="fas fa-filter"></i>
        <span>Filters</span>
        @if (ActiveFilterCount > 0)
        {
            <span class="badge bg-light text-primary rounded-pill">@ActiveFilterCount</span>
        }
    </button>

    @if (ActiveFilterCount > 0)
    {
        <button class="btn btn-link text-decoration-none p-0 ms-2"
                @onclick="ResetAllFilters"
                @onclick:stopPropagation="true">
            <i class="fas fa-undo me-1"></i>
            Reset filters
        </button>
    }

    <!-- Filter Panel Dropdown -->
    @if (_isPanelOpen)
    {
        <div class="filter-panel-dropdown"
             id="@_dropdownId"
             @onclick:stopPropagation="true">
            <div class="filter-panel-header">
                <h6 class="mb-0 fw-semibold">Filter By</h6>
                <div class="d-flex align-items-center gap-2">
                    @if (_activeFilters.Any() && ShowSaveView)
                    {
                        <button class="btn btn-link btn-sm text-decoration-none p-0"
                                @onclick="OpenSaveViewDialog"
                                @onclick:stopPropagation="true">
                            Save view <i class="fas fa-chevron-right ms-1"></i>
                        </button>
                    }
                    <button class="btn btn-sm btn-link text-muted p-0 ms-2"
                            @onclick="ClosePanel"
                            @onclick:stopPropagation="true"
                            title="Close">
                        <i class="fas fa-times"></i>
                    </button>
                </div>
            </div>

            <div class="filter-panel-body">
                <!-- Saved Views Dropdown -->
                @if (ShowSaveView && _savedViews.Any())
                {
                    <div class="p-3 border-bottom">
                        <select class="form-select form-select-sm"
                                @onchange="LoadSelectedView"
                                @onclick:stopPropagation="true">
                            <option value="">Select a saved view...</option>
                            @foreach (var view in _savedViews)
                            {
                                <option value="@view.Id">@view.Name</option>
                            }
                        </select>
                    </div>
                }

                <!-- Active Filters List -->
                @if (_activeFilters.Any())
                {
                    <div class="active-filters-section border-bottom">
                        <div class="px-3 py-2 bg-light">
                            <small class="text-muted fw-semibold">Active Filters</small>
                        </div>
                        @foreach (var filter in _activeFilters)
                        {
                            var column = Columns.FirstOrDefault(c => c.PropertyName == filter.Key);
                            if (column != null)
                            {
                                <div class="filter-item d-flex justify-content-between align-items-center px-3 py-2 border-bottom">
                                    <div class="d-flex align-items-center gap-2">
                                        <i class="@GetFilterTypeIcon(column.FilterType) text-muted"></i>
                                        <div>
                                            <div class="fw-medium small">@column.DisplayName</div>
                                            <div class="text-muted small">@GetFilterDescription(filter.Value, column)</div>
                                        </div>
                                    </div>
                                    <div class="d-flex gap-1">
                                        <button class="btn btn-sm btn-link text-primary p-1"
                                                @onclick="() => EditFilter(column)"
                                                @onclick:stopPropagation="true"
                                                title="Edit">
                                            <i class="fas fa-pen"></i>
                                        </button>
                                        <button class="btn btn-sm btn-link text-danger p-1"
                                                @onclick="() => RemoveFilter(filter.Key)"
                                                @onclick:stopPropagation="true"
                                                title="Remove">
                                            <i class="fas fa-times"></i>
                                        </button>
                                    </div>
                                </div>
                            }
                        }
                    </div>
                }

                <!-- Column Selection / Add Filter -->
                @if (!_isConfiguringFilter)
                {
                    <div class="column-list">
                        <div class="px-3 py-2 bg-light">
                            <small class="text-muted fw-semibold">Add Filter</small>
                        </div>
                        @foreach (var column in Columns)
                        {
                            var filterCount = _activeFilters.ContainsKey(column.PropertyName) ? 1 : 0;
                            <div class="filter-type-item d-flex justify-content-between align-items-center px-3 py-2 border-bottom"
                                 @onclick="() => SelectColumnToFilter(column)"
                                 @onclick:stopPropagation="true">
                                <div class="d-flex align-items-center gap-2">
                                    <i class="@GetFilterTypeIcon(column.FilterType) text-muted"></i>
                                    <span>@column.DisplayName</span>
                                    @if (filterCount > 0)
                                    {
                                        <span class="badge bg-primary rounded-pill">@filterCount</span>
                                    }
                                </div>
                                <i class="fas fa-plus text-muted"></i>
                            </div>
                        }
                    </div>
                }
                else
                {
                    <!-- Filter Configuration -->
                    <div class="filter-config p-3">
                        <div class="d-flex align-items-center gap-2 mb-3">
                            <button class="btn btn-sm btn-link p-0"
                                    @onclick="CancelFilterConfig"
                                    @onclick:stopPropagation="true">
                                <i class="fas fa-arrow-left"></i>
                            </button>
                            <h6 class="mb-0">@_selectedColumn?.DisplayName</h6>
                        </div>

                        @if (_selectedColumn != null)
                        {
                            <!-- Operator Selection -->
                            <div class="mb-3">
                                <label class="form-label small text-muted">Condition</label>
                                <select class="form-select form-select-sm"
                                        @bind="_selectedOperator"
                                        @onclick:stopPropagation="true">
                                    @foreach (var op in _selectedColumn.GetAvailableOperators())
                                    {
                                        <option value="@op.Value">@op.Label</option>
                                    }
                                </select>
                            </div>

                            <!-- Value Input based on Filter Type -->
                            @switch (_selectedColumn.FilterType)
                            {
                                case FilterType.String:
                                    <div class="mb-3">
                                        <label class="form-label small text-muted">Value</label>
                                        @if (_selectedColumn.SelectionOptions?.Any() == true)
                                        {
                                            <select class="form-select form-select-sm"
                                                    @bind="_filterValue"
                                                    @onclick:stopPropagation="true">
                                                <option value="">Select...</option>
                                                @foreach (var option in _selectedColumn.SelectionOptions)
                                                {
                                                    <option value="@option">@option</option>
                                                }
                                            </select>
                                        }
                                        else
                                        {
                                            <input type="text" class="form-control form-control-sm"
                                                   @bind="_filterValue"
                                                   @onclick:stopPropagation="true"
                                                   placeholder="Enter value..." />
                                        }
                                    </div>
                                    break;

                                case FilterType.Numeric:
                                    <div class="mb-3">
                                        <label class="form-label small text-muted">Value</label>
                                        <input type="number" class="form-control form-control-sm"
                                               @bind="_filterValue"
                                               @onclick:stopPropagation="true"
                                               placeholder="Enter number..." />
                                    </div>
                                    @if (_selectedOperator == "between")
                                    {
                                        <div class="mb-3">
                                            <label class="form-label small text-muted">And</label>
                                            <input type="number" class="form-control form-control-sm"
                                                   @bind="_filterValue2"
                                                   @onclick:stopPropagation="true"
                                                   placeholder="Enter second number..." />
                                        </div>
                                    }
                                    break;

                                case FilterType.Date:
                                    <div class="mb-3">
                                        <label class="form-label small text-muted">Date</label>
                                        <input type="date" class="form-control form-control-sm"
                                               @bind="_filterDateValue"
                                               @onclick:stopPropagation="true" />
                                    </div>
                                    @if (_selectedOperator == "between")
                                    {
                                        <div class="mb-3">
                                            <label class="form-label small text-muted">And</label>
                                            <input type="date" class="form-control form-control-sm"
                                                   @bind="_filterDateValue2"
                                                   @onclick:stopPropagation="true" />
                                        </div>
                                    }
                                    break;

                                case FilterType.Boolean:
                                    <!-- Boolean doesn't need value input, operator IS the value -->
                                    break;

                                case FilterType.Enum:
                                    <div class="mb-3">
                                        <label class="form-label small text-muted">Value</label>
                                        <select class="form-select form-select-sm"
                                                @bind="_filterValue"
                                                @onclick:stopPropagation="true">
                                            <option value="">Select...</option>
                                            @if (_selectedColumn.EnumValues != null)
                                            {
                                                @foreach (var enumValue in _selectedColumn.EnumValues)
                                                {
                                                    <option value="@enumValue">@enumValue</option>
                                                }
                                            }
                                        </select>
                                    </div>
                                    break;
                            }

                            <div class="d-flex gap-2">
                                <button class="btn btn-primary btn-sm flex-grow-1"
                                        @onclick="ApplyFilter"
                                        @onclick:stopPropagation="true">
                                    Apply Filter
                                </button>
                                <button class="btn btn-outline-secondary btn-sm"
                                        @onclick="CancelFilterConfig"
                                        @onclick:stopPropagation="true">
                                    Cancel
                                </button>
                            </div>
                        }
                    </div>
                }
            </div>
        </div>
    }
</div>

<!-- Save View Modal -->
@if (_isSaveViewDialogOpen)
{
    <div class="save-view-overlay" @onclick="CloseSaveViewDialog" @onclick:stopPropagation="true"></div>
    <div class="save-view-dialog" @onclick:stopPropagation="true">
        <div class="save-view-header">
            <h6 class="mb-0">Save Filter View</h6>
        </div>
        <div class="save-view-body">
            <div class="mb-3">
                <label class="form-label small">View Name</label>
                <input type="text" class="form-control form-control-sm"
                       @bind="_newViewName"
                       @onclick:stopPropagation="true"
                       placeholder="Enter view name..." />
            </div>
            <div class="d-flex gap-2">
                <button class="btn btn-primary btn-sm flex-grow-1"
                        @onclick="SaveView"
                        @onclick:stopPropagation="true">
                    Save
                </button>
                <button class="btn btn-outline-secondary btn-sm"
                        @onclick="CloseSaveViewDialog"
                        @onclick:stopPropagation="true">
                    Cancel
                </button>
            </div>
        </div>
    </div>
}

<style>
    /* Backdrop - full screen layer to catch outside clicks */
    .filter-panel-backdrop {
        position: fixed;
        inset: 0;
        z-index: 9998;
        background: transparent;
        cursor: default;
    }

    /* Container - relative positioning for dropdown */
    .filter-panel-container {
        position: relative;
        display: inline-flex;
        align-items: center;
    }

    /* Dropdown panel */
    .filter-panel-dropdown {
        position: absolute;
        top: calc(100% + 4px);
        left: 0;
        z-index: 9999;
        width: 320px;
        max-height: 450px;
        overflow-y: auto;
        background-color: #ffffff;
        border: 1px solid rgba(0, 0, 0, 0.15);
        border-radius: 0.375rem;
        box-shadow: 0 0.5rem 1rem rgba(0, 0, 0, 0.175);
    }

    .filter-panel-header {
        display: flex;
        justify-content: space-between;
        align-items: center;
        padding: 0.75rem 1rem;
        background-color: #fff;
        border-bottom: 1px solid #dee2e6;
        position: sticky;
        top: 0;
        z-index: 1;
    }

    .filter-panel-body {
        background-color: #fff;
    }

    /* Filter items */
    .filter-type-item {
        cursor: pointer;
        background-color: #fff;
        user-select: none;
    }

    .filter-type-item:hover {
        background-color: #f8f9fa;
    }

    .filter-item {
        background-color: #fff;
    }

    .filter-item:hover {
        background-color: #f8f9fa;
    }

    /* Save View Modal */
    .save-view-overlay {
        position: fixed;
        inset: 0;
        z-index: 10000;
        background: rgba(0, 0, 0, 0.3);
    }

    .save-view-dialog {
        position: fixed;
        top: 50%;
        left: 50%;
        transform: translate(-50%, -50%);
        z-index: 10001;
        width: 300px;
        background-color: #fff;
        border-radius: 0.375rem;
        box-shadow: 0 0.5rem 1rem rgba(0, 0, 0, 0.175);
    }

    .save-view-header {
        padding: 0.75rem 1rem;
        border-bottom: 1px solid #dee2e6;
    }

    .save-view-body {
        padding: 1rem;
    }
</style>
