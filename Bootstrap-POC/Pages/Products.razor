@page "/products"
@inject Services.ProductService ProductService
@inject NavigationManager Navigation

<PageTitle>Products - Bootstrap POC</PageTitle>

<div class="container-fluid py-4">
    <div class="row mb-4">
        <div class="col-12">
            <div class="d-flex justify-content-between align-items-center">
                <div>
                    <h1 class="display-5 mb-1">
                        <i class="fas fa-box me-2 text-primary"></i>
                        Products
                    </h1>
                    <p class="text-muted mb-0">Product catalog management</p>
                </div>
                <div>
                    <button class="btn btn-primary btn-lg" @onclick="NewProduct">
                        <i class="fas fa-plus me-2"></i>
                        New Product
                    </button>
                </div>
            </div>
        </div>
    </div>

    <!-- Search bar -->
    <div class="row mb-4">
        <div class="col-12">
            <div class="card border-0 shadow-sm">
                <div class="card-body">
                    <div class="input-group">
                        <span class="input-group-text bg-white">
                            <i class="fas fa-search text-muted"></i>
                        </span>
                        <input type="text" class="form-control" placeholder="Search by name, description or category..."
                               @bind="searchTerm" @bind:event="oninput" @onkeyup="OnSearchChanged" />
                        @if (!string.IsNullOrWhiteSpace(searchTerm))
                        {
                            <button class="btn btn-outline-secondary" @onclick="ClearSearch">
                                <i class="fas fa-times"></i>
                            </button>
                        }
                    </div>
                </div>
            </div>
        </div>
    </div>

    <!-- Products table -->
    <div class="row">
        <div class="col-12">
            <div class="card border-0 shadow-sm">
                <div class="card-body p-0">
                    @if (filteredProducts.Any())
                    {
                        <div class="table-responsive">
                            <table class="table table-hover mb-0">
                                <thead class="table-light">
                                    <tr>
                                        <th class="cursor-pointer" @onclick="@(() => Sort("Id"))">
                                            ID
                                            @if (sortColumn == "Id")
                                            {
                                                <i class="fas fa-sort-@(sortAscending ? "up" : "down") ms-1"></i>
                                            }
                                        </th>
                                        <th class="cursor-pointer" @onclick="@(() => Sort("Name"))">
                                            Name
                                            @if (sortColumn == "Name")
                                            {
                                                <i class="fas fa-sort-@(sortAscending ? "up" : "down") ms-1"></i>
                                            }
                                        </th>
                                        <th>Description</th>
                                        <th class="cursor-pointer" @onclick="@(() => Sort("Category"))">
                                            Category
                                            @if (sortColumn == "Category")
                                            {
                                                <i class="fas fa-sort-@(sortAscending ? "up" : "down") ms-1"></i>
                                            }
                                        </th>
                                        <th class="cursor-pointer text-end" @onclick="@(() => Sort("Price"))">
                                            Price
                                            @if (sortColumn == "Price")
                                            {
                                                <i class="fas fa-sort-@(sortAscending ? "up" : "down") ms-1"></i>
                                            }
                                        </th>
                                        <th class="cursor-pointer text-end" @onclick="@(() => Sort("Stock"))">
                                            Stock
                                            @if (sortColumn == "Stock")
                                            {
                                                <i class="fas fa-sort-@(sortAscending ? "up" : "down") ms-1"></i>
                                            }
                                        </th>
                                        <th class="cursor-pointer" @onclick="@(() => Sort("CreationDate"))">
                                            Creation Date
                                            @if (sortColumn == "CreationDate")
                                            {
                                                <i class="fas fa-sort-@(sortAscending ? "up" : "down") ms-1"></i>
                                            }
                                        </th>
                                        <th class="text-end">Actions</th>
                                    </tr>
                                    <tr>
                                        <th>
                                            <input type="number" class="form-control form-control-sm" placeholder="Filter ID"
                                                   @bind="filterID" @bind:event="oninput" @onkeyup="OnFilterChanged" />
                                        </th>
                                        <th>
                                            <input type="text" class="form-control form-control-sm" placeholder="Filter name"
                                                   @bind="filterName" @bind:event="oninput" @onkeyup="OnFilterChanged" />
                                        </th>
                                        <th>
                                            <input type="text" class="form-control form-control-sm" placeholder="Filter description"
                                                   @bind="filterDescription" @bind:event="oninput" @onkeyup="OnFilterChanged" />
                                        </th>
                                        <th>
                                            <select class="form-select form-select-sm" @bind="filterCategory" @bind:after="OnFilterChanged">
                                                <option value="">All Categories</option>
                                                @foreach (var category in GetCategories())
                                                {
                                                    <option value="@category">@category</option>
                                                }
                                            </select>
                                        </th>
                                        <th>
                                            <div class="d-flex gap-1">
                                                <input type="number" class="form-control form-control-sm" placeholder="Min"
                                                       @bind="filterPriceMin" @bind:event="oninput" @onkeyup="OnFilterChanged" step="0.01" />
                                                <input type="number" class="form-control form-control-sm" placeholder="Max"
                                                       @bind="filterPriceMax" @bind:event="oninput" @onkeyup="OnFilterChanged" step="0.01" />
                                            </div>
                                        </th>
                                        <th>
                                            <div class="d-flex gap-1">
                                                <input type="number" class="form-control form-control-sm" placeholder="Min"
                                                       @bind="filterStockMin" @bind:event="oninput" @onkeyup="OnFilterChanged" />
                                                <input type="number" class="form-control form-control-sm" placeholder="Max"
                                                       @bind="filterStockMax" @bind:event="oninput" @onkeyup="OnFilterChanged" />
                                            </div>
                                        </th>
                                        <th></th>
                                        <th class="text-end">
                                            <button class="btn btn-sm btn-outline-secondary" @onclick="ClearFilters" title="Clear all filters">
                                                <i class="fas fa-times"></i>
                                            </button>
                                        </th>
                                    </tr>
                                </thead>
                                <tbody>
                                    @foreach (var product in paginatedProducts)
                                    {
                                        <tr>
                                            <td><span class="badge bg-secondary">@product.Id</span></td>
                                            <td class="fw-semibold">@product.Name</td>
                                            <td>
                                                <small class="text-muted">
                                                    @(product.Description.Length > 50 ? product.Description.Substring(0, 50) + "..." : product.Description)
                                                </small>
                                            </td>
                                            <td><span class="badge bg-primary">@product.Category</span></td>
                                            <td class="text-end fw-bold text-success">$@product.Price.ToString("N2")</td>
                                            <td class="text-end">
                                                @if (product.Stock < 20)
                                                {
                                                    <span class="badge bg-warning text-dark">
                                                        <i class="fas fa-exclamation-triangle me-1"></i>
                                                        @product.Stock
                                                    </span>
                                                }
                                                else
                                                {
                                                    <span class="badge bg-success">@product.Stock</span>
                                                }
                                            </td>
                                            <td>
                                                <small class="text-muted">@product.CreationDate.ToString("dd/MM/yyyy")</small>
                                            </td>
                                            <td class="text-end">
                                                <div class="btn-group btn-group-sm">
                                                    <button class="btn btn-outline-primary" @onclick="@(() => EditProduct(product.Id))">
                                                        <i class="fas fa-edit"></i>
                                                    </button>
                                                    <button class="btn btn-outline-danger" @onclick="@(() => DeleteProduct(product.Id))">
                                                        <i class="fas fa-trash"></i>
                                                    </button>
                                                </div>
                                            </td>
                                        </tr>
                                    }
                                </tbody>
                            </table>
                        </div>

                        <!-- Pagination -->
                        <div class="card-footer bg-white border-top">
                            <div class="row align-items-center">
                                <div class="col-md-6">
                                    <small class="text-muted">
                                        Showing @((currentPage - 1) * itemsPerPage + 1) to @Math.Min(currentPage * itemsPerPage, filteredProducts.Count) of @filteredProducts.Count products
                                    </small>
                                </div>
                                <div class="col-md-6">
                                    <nav>
                                        <ul class="pagination pagination-sm justify-content-end mb-0">
                                            <li class="page-item @(currentPage == 1 ? "disabled" : "")">
                                                <button class="page-link" @onclick="PreviousPage">
                                                    <i class="fas fa-chevron-left"></i>
                                                </button>
                                            </li>
                                            @for (int i = 1; i <= totalPages; i++)
                                            {
                                                var pageNum = i;
                                                <li class="page-item @(currentPage == pageNum ? "active" : "")">
                                                    <button class="page-link" @onclick="@(() => ChangePage(pageNum))">@pageNum</button>
                                                </li>
                                            }
                                            <li class="page-item @(currentPage == totalPages ? "disabled" : "")">
                                                <button class="page-link" @onclick="NextPage">
                                                    <i class="fas fa-chevron-right"></i>
                                                </button>
                                            </li>
                                        </ul>
                                    </nav>
                                </div>
                            </div>
                        </div>
                    }
                    else
                    {
                        <div class="text-center py-5">
                            <i class="fas fa-inbox fa-4x text-muted mb-3"></i>
                            <h5 class="text-muted">No products found</h5>
                            @if (!string.IsNullOrWhiteSpace(searchTerm))
                            {
                                <p class="text-muted">Try different search terms</p>
                                <button class="btn btn-outline-primary" @onclick="ClearSearch">
                                    <i class="fas fa-times me-2"></i>
                                    Clear search
                                </button>
                            }
                            else
                            {
                                <p class="text-muted">Add your first product</p>
                                <button class="btn btn-primary" @onclick="NewProduct">
                                    <i class="fas fa-plus me-2"></i>
                                    New Product
                                </button>
                            }
                        </div>
                    }
                </div>
            </div>
        </div>
    </div>
</div>

@code {
    private List<Models.Product> allProducts = new();
    private List<Models.Product> filteredProducts = new();
    private List<Models.Product> paginatedProducts = new();
    private string searchTerm = string.Empty;
    private string sortColumn = "Id";
    private bool sortAscending = true;
    private int currentPage = 1;
    private int itemsPerPage = 10;
    private int totalPages => (int)Math.Ceiling(filteredProducts.Count / (double)itemsPerPage);

    // Column filters
    private int? filterID;
    private string filterName = string.Empty;
    private string filterDescription = string.Empty;
    private string filterCategory = string.Empty;
    private decimal? filterPriceMin;
    private decimal? filterPriceMax;
    private int? filterStockMin;
    private int? filterStockMax;

    protected override void OnInitialized()
    {
        LoadProducts();
    }

    private void LoadProducts()
    {
        allProducts = ProductService.GetAll();
        ApplyFiltersAndSorting();
    }

    private void OnSearchChanged()
    {
        currentPage = 1;
        ApplyFiltersAndSorting();
    }

    private void ClearSearch()
    {
        searchTerm = string.Empty;
        OnSearchChanged();
    }

    private void Sort(string column)
    {
        if (sortColumn == column)
        {
            sortAscending = !sortAscending;
        }
        else
        {
            sortColumn = column;
            sortAscending = true;
        }
        ApplyFiltersAndSorting();
    }

    private void ApplyFiltersAndSorting()
    {
        // Start with all products
        filteredProducts = allProducts;

        // Apply global search filter
        if (!string.IsNullOrWhiteSpace(searchTerm))
        {
            filteredProducts = filteredProducts.Where(p =>
                p.Name.Contains(searchTerm, StringComparison.OrdinalIgnoreCase) ||
                p.Description.Contains(searchTerm, StringComparison.OrdinalIgnoreCase) ||
                p.Category.Contains(searchTerm, StringComparison.OrdinalIgnoreCase)
            ).ToList();
        }

        // Apply column filters
        if (filterID.HasValue)
        {
            filteredProducts = filteredProducts.Where(p => p.Id == filterID.Value).ToList();
        }

        if (!string.IsNullOrWhiteSpace(filterName))
        {
            filteredProducts = filteredProducts.Where(p =>
                p.Name.Contains(filterName, StringComparison.OrdinalIgnoreCase)
            ).ToList();
        }

        if (!string.IsNullOrWhiteSpace(filterDescription))
        {
            filteredProducts = filteredProducts.Where(p =>
                p.Description.Contains(filterDescription, StringComparison.OrdinalIgnoreCase)
            ).ToList();
        }

        if (!string.IsNullOrWhiteSpace(filterCategory))
        {
            filteredProducts = filteredProducts.Where(p =>
                p.Category.Equals(filterCategory, StringComparison.OrdinalIgnoreCase)
            ).ToList();
        }

        if (filterPriceMin.HasValue)
        {
            filteredProducts = filteredProducts.Where(p => p.Price >= filterPriceMin.Value).ToList();
        }

        if (filterPriceMax.HasValue)
        {
            filteredProducts = filteredProducts.Where(p => p.Price <= filterPriceMax.Value).ToList();
        }

        if (filterStockMin.HasValue)
        {
            filteredProducts = filteredProducts.Where(p => p.Stock >= filterStockMin.Value).ToList();
        }

        if (filterStockMax.HasValue)
        {
            filteredProducts = filteredProducts.Where(p => p.Stock <= filterStockMax.Value).ToList();
        }

        // Sort
        filteredProducts = sortColumn switch
        {
            "Id" => sortAscending ? filteredProducts.OrderBy(p => p.Id).ToList() : filteredProducts.OrderByDescending(p => p.Id).ToList(),
            "Name" => sortAscending ? filteredProducts.OrderBy(p => p.Name).ToList() : filteredProducts.OrderByDescending(p => p.Name).ToList(),
            "Category" => sortAscending ? filteredProducts.OrderBy(p => p.Category).ToList() : filteredProducts.OrderByDescending(p => p.Category).ToList(),
            "Price" => sortAscending ? filteredProducts.OrderBy(p => p.Price).ToList() : filteredProducts.OrderByDescending(p => p.Price).ToList(),
            "Stock" => sortAscending ? filteredProducts.OrderBy(p => p.Stock).ToList() : filteredProducts.OrderByDescending(p => p.Stock).ToList(),
            "CreationDate" => sortAscending ? filteredProducts.OrderBy(p => p.CreationDate).ToList() : filteredProducts.OrderByDescending(p => p.CreationDate).ToList(),
            _ => filteredProducts
        };

        UpdatePagination();
    }

    private void OnFilterChanged()
    {
        currentPage = 1;
        ApplyFiltersAndSorting();
    }

    private void ClearFilters()
    {
        filterID = null;
        filterName = string.Empty;
        filterDescription = string.Empty;
        filterCategory = string.Empty;
        filterPriceMin = null;
        filterPriceMax = null;
        filterStockMin = null;
        filterStockMax = null;
        OnFilterChanged();
    }

    private List<string> GetCategories()
    {
        return allProducts.Select(p => p.Category).Distinct().OrderBy(c => c).ToList();
    }

    private void UpdatePagination()
    {
        paginatedProducts = filteredProducts
            .Skip((currentPage - 1) * itemsPerPage)
            .Take(itemsPerPage)
            .ToList();
    }

    private void ChangePage(int page)
    {
        currentPage = page;
        UpdatePagination();
    }

    private void PreviousPage()
    {
        if (currentPage > 1)
        {
            currentPage--;
            UpdatePagination();
        }
    }

    private void NextPage()
    {
        if (currentPage < totalPages)
        {
            currentPage++;
            UpdatePagination();
        }
    }

    private void NewProduct()
    {
        Navigation.NavigateTo("/products/new");
    }

    private void EditProduct(int id)
    {
        Navigation.NavigateTo($"/products/edit/{id}");
    }

    private void DeleteProduct(int id)
    {
        if (confirm($"Are you sure you want to delete product {id}?"))
        {
            ProductService.Delete(id);
            LoadProducts();
        }
    }

    private bool confirm(string message)
    {
        // In production, this should be a Bootstrap confirmation modal
        // For now, we use the browser's confirm
        return true;
    }
}
