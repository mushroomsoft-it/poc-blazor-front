@page "/products"
@inject Services.ProductService ProductService
@inject NavigationManager Navigation
@using Bootstrap_POC.Components.DataGrid.Filters

<PageTitle>Products - Bootstrap POC</PageTitle>

<div class="container-fluid py-4">
    <div class="row mb-4">
        <div class="col-12">
            <div class="d-flex justify-content-between align-items-center">
                <div>
                    <h1 class="display-5 mb-1">
                        <i class="fas fa-box me-2 text-primary"></i>
                        Products
                    </h1>
                    <p class="text-muted mb-0">Product catalog management</p>
                </div>
                <div>
                    <button class="btn btn-primary btn-lg" @onclick="NewProduct">
                        <i class="fas fa-plus me-2"></i>
                        New Product
                    </button>
                </div>
            </div>
        </div>
    </div>

    <!-- Search bar -->
    <div class="row mb-4">
        <div class="col-12">
            <div class="card border-0 shadow-sm">
                <div class="card-body">
                    <div class="input-group">
                        <span class="input-group-text bg-white">
                            <i class="fas fa-search text-muted"></i>
                        </span>
                        <input type="text" class="form-control" placeholder="Search by name, description or category..."
                               @bind="searchTerm" @bind:event="oninput" @onkeyup="OnSearchChanged" />
                        @if (!string.IsNullOrWhiteSpace(searchTerm))
                        {
                            <button class="btn btn-outline-secondary" @onclick="ClearSearch">
                                <i class="fas fa-times"></i>
                            </button>
                        }
                    </div>
                </div>
            </div>
        </div>
    </div>

    <!-- Products DataGrid -->
    <div class="row">
        <div class="col-12">
            <div class="card border-0 shadow-sm" style="overflow: visible;">
                <div class="card-body p-0" style="overflow: visible;">
                    <DataGrid TItem="Product"
                              Items="@displayedProducts"
                              TotalCount="@filteredCount"
                              CurrentPage="@currentPage"
                              PageSize="10"
                              SortColumn="@sortColumn"
                              SortAscending="@sortAscending"
                              OnPageChanged="HandlePageChanged"
                              OnSortChanged="HandleSortChanged"
                              OnFilterChanged="HandleFilterChanged"
                              FixedLayout="true">
                        <Columns>
                            <GridColumn TItem="Product" PropertyName="Id" Width="80px" Title="ID" />
                            <GridColumn TItem="Product" PropertyName="Name" Width="200px" />
                            <GridColumn TItem="Product" PropertyName="Description" Width="auto" Sortable="false">
                                <Template Context="product">
                                    <small class="text-muted">
                                        @(product.Description.Length > 50 ? product.Description.Substring(0, 50) + "..." : product.Description)
                                    </small>
                                </Template>
                            </GridColumn>
                            <GridColumn TItem="Product" PropertyName="Category" Width="120px" FilterOptions="@AvailableCategories">
                                <Template Context="product">
                                    <span class="badge bg-primary">@product.Category</span>
                                </Template>
                            </GridColumn>
                            <GridColumn TItem="Product" PropertyName="Price" Width="100px" Format="N2" Alignment="TextAlignment.Right">
                                <Template Context="product">
                                    <span class="fw-bold text-success">$@product.Price.ToString("N2")</span>
                                </Template>
                            </GridColumn>
                            <GridColumn TItem="Product" PropertyName="Stock" Width="100px" Alignment="TextAlignment.Right">
                                <Template Context="product">
                                    @if (product.Stock < 20)
                                    {
                                        <span class="badge bg-warning text-dark">
                                            <i class="fas fa-exclamation-triangle me-1"></i>
                                            @product.Stock
                                        </span>
                                    }
                                    else
                                    {
                                        <span class="badge bg-success">@product.Stock</span>
                                    }
                                </Template>
                            </GridColumn>
                            <GridColumn TItem="Product" PropertyName="CreationDate" Width="140px" Format="dd/MM/yyyy" Title="Creation Date" />
                        </Columns>
                        <RowActions Context="product">
                            <div class="btn-group btn-group-sm">
                                <button class="btn btn-outline-primary" @onclick="@(() => EditProduct(product.Id))">
                                    <i class="fas fa-edit"></i>
                                </button>
                                <button class="btn btn-outline-danger" @onclick="@(() => DeleteProduct(product.Id))">
                                    <i class="fas fa-trash"></i>
                                </button>
                            </div>
                        </RowActions>
                        <EmptyContent>
                            <div class="text-center py-5">
                                <i class="fas fa-inbox fa-3x text-muted mb-3 d-block"></i>
                                <h5 class="text-muted">No products found</h5>
                                @if (activeFilters.Any() || !string.IsNullOrWhiteSpace(searchTerm))
                                {
                                    <p class="text-muted">Try adjusting your filters or search terms</p>
                                    <div class="d-flex gap-2 justify-content-center">
                                        @if (!string.IsNullOrWhiteSpace(searchTerm))
                                        {
                                            <button class="btn btn-sm btn-outline-primary" @onclick="ClearSearch">
                                                <i class="fas fa-times me-2"></i>Clear search
                                            </button>
                                        }
                                        @if (activeFilters.Any())
                                        {
                                            <button class="btn btn-sm btn-outline-secondary" @onclick="ClearAllFilters">
                                                <i class="fas fa-filter me-2"></i>Clear filters
                                            </button>
                                        }
                                    </div>
                                }
                                else
                                {
                                    <p class="text-muted">Add your first product</p>
                                    <button class="btn btn-primary" @onclick="NewProduct">
                                        <i class="fas fa-plus me-2"></i>New Product
                                    </button>
                                }
                            </div>
                        </EmptyContent>
                    </DataGrid>
                </div>
            </div>
        </div>
    </div>
</div>

@code {
    private List<Product> allProducts = new();
    private List<Product> displayedProducts = new();
    private int filteredCount = 0;
    private string searchTerm = string.Empty;
    private string sortColumn = "Id";
    private bool sortAscending = true;
    private int currentPage = 1;
    private Dictionary<string, FilterState> activeFilters = new();

    private List<string> AvailableCategories => allProducts
        .Select(p => p.Category)
        .Distinct()
        .OrderBy(c => c)
        .ToList();

    protected override void OnInitialized()
    {
        LoadProducts();
    }

    private void LoadProducts()
    {
        allProducts = ProductService.GetAll();
        ApplyFiltersAndLoadPage();
    }

    private void OnSearchChanged()
    {
        currentPage = 1;
        ApplyFiltersAndLoadPage();
    }

    private void ClearSearch()
    {
        searchTerm = string.Empty;
        OnSearchChanged();
    }

    private void HandleFilterChanged(FilterChangeEventArgs args)
    {
        activeFilters = args.AllFilters;
        currentPage = 1;
        ApplyFiltersAndLoadPage();
    }

    private void HandleSortChanged((string Column, bool Ascending) sortInfo)
    {
        sortColumn = sortInfo.Column;
        sortAscending = sortInfo.Ascending;
        ApplyFiltersAndLoadPage();
    }

    private void HandlePageChanged(int page)
    {
        currentPage = page;
        ApplyFiltersAndLoadPage();
    }

    private void ClearAllFilters()
    {
        activeFilters.Clear();
        currentPage = 1;
        ApplyFiltersAndLoadPage();
    }

    private void ApplyFiltersAndLoadPage()
    {
        var filtered = allProducts.AsEnumerable();

        // Apply search term
        if (!string.IsNullOrWhiteSpace(searchTerm))
        {
            filtered = filtered.Where(p =>
                p.Name.Contains(searchTerm, StringComparison.OrdinalIgnoreCase) ||
                p.Description.Contains(searchTerm, StringComparison.OrdinalIgnoreCase) ||
                p.Category.Contains(searchTerm, StringComparison.OrdinalIgnoreCase));
        }

        // Apply column filters
        foreach (var filter in activeFilters.Values)
        {
            filtered = ApplyFilter(filtered, filter);
        }

        // Apply sorting
        filtered = ApplySorting(filtered);

        var filteredList = filtered.ToList();
        filteredCount = filteredList.Count;

        // Apply pagination
        displayedProducts = filteredList
            .Skip((currentPage - 1) * 10)
            .Take(10)
            .ToList();

        StateHasChanged();
    }

    private IEnumerable<Product> ApplyFilter(IEnumerable<Product> products, FilterState filter)
    {
        return filter.PropertyName switch
        {
            "Id" => ApplyNumericFilter(products, p => p.Id, filter),
            "Name" => ApplyStringFilter(products, p => p.Name, filter),
            "Description" => ApplyStringFilter(products, p => p.Description, filter),
            "Category" => ApplyStringFilter(products, p => p.Category, filter),
            "Price" => ApplyNumericFilter(products, p => (int)(p.Price * 100), filter),
            "Stock" => ApplyNumericFilter(products, p => p.Stock, filter),
            "CreationDate" => ApplyDateFilter(products, p => p.CreationDate, filter),
            _ => products
        };
    }

    private IEnumerable<Product> ApplyNumericFilter<T>(IEnumerable<Product> products, Func<Product, T> selector, FilterState filter)
        where T : IComparable<T>
    {
        if (filter.Value == null) return products;

        return filter.Operator switch
        {
            FilterOperator.Equals => products.Where(p => selector(p).CompareTo((T)filter.Value) == 0),
            FilterOperator.GreaterThan => products.Where(p => selector(p).CompareTo((T)filter.Value) > 0),
            FilterOperator.LessThan => products.Where(p => selector(p).CompareTo((T)filter.Value) < 0),
            FilterOperator.Between when filter.Value2 != null =>
                products.Where(p => selector(p).CompareTo((T)filter.Value) >= 0 && selector(p).CompareTo((T)filter.Value2) <= 0),
            _ => products
        };
    }

    private IEnumerable<Product> ApplyStringFilter(IEnumerable<Product> products, Func<Product, string> selector, FilterState filter)
    {
        if (filter.Value == null) return products;
        var filterValue = filter.Value.ToString() ?? string.Empty;

        return filter.Operator switch
        {
            FilterOperator.Contains => products.Where(p => selector(p).Contains(filterValue, StringComparison.OrdinalIgnoreCase)),
            FilterOperator.Equals => products.Where(p => selector(p).Equals(filterValue, StringComparison.OrdinalIgnoreCase)),
            _ => products
        };
    }

    private IEnumerable<Product> ApplyDateFilter(IEnumerable<Product> products, Func<Product, DateTime> selector, FilterState filter)
    {
        if (filter.Value == null) return products;
        var filterDate = (DateTime)filter.Value;

        return filter.Operator switch
        {
            FilterOperator.Equals => products.Where(p => selector(p).Date == filterDate.Date),
            FilterOperator.After => products.Where(p => selector(p).Date > filterDate.Date),
            FilterOperator.Before => products.Where(p => selector(p).Date < filterDate.Date),
            FilterOperator.Between when filter.Value2 != null =>
                products.Where(p => selector(p).Date >= filterDate.Date && selector(p).Date <= ((DateTime)filter.Value2).Date),
            _ => products
        };
    }

    private IEnumerable<Product> ApplySorting(IEnumerable<Product> products)
    {
        return sortColumn switch
        {
            "Id" => sortAscending ? products.OrderBy(p => p.Id) : products.OrderByDescending(p => p.Id),
            "Name" => sortAscending ? products.OrderBy(p => p.Name) : products.OrderByDescending(p => p.Name),
            "Category" => sortAscending ? products.OrderBy(p => p.Category) : products.OrderByDescending(p => p.Category),
            "Price" => sortAscending ? products.OrderBy(p => p.Price) : products.OrderByDescending(p => p.Price),
            "Stock" => sortAscending ? products.OrderBy(p => p.Stock) : products.OrderByDescending(p => p.Stock),
            "CreationDate" => sortAscending ? products.OrderBy(p => p.CreationDate) : products.OrderByDescending(p => p.CreationDate),
            _ => products
        };
    }

    private void NewProduct()
    {
        Navigation.NavigateTo("/products/new");
    }

    private void EditProduct(int id)
    {
        Navigation.NavigateTo($"/products/edit/{id}");
    }

    private void DeleteProduct(int id)
    {
        // In production, this should be a Bootstrap confirmation modal
        ProductService.Delete(id);
        LoadProducts();
    }
}
