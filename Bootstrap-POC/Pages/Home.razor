@page "/"
@inject Services.StatisticsService StatisticsService
@inject NavigationManager Navigation

<PageTitle>Dashboard - Bootstrap POC</PageTitle>

<div class="container-fluid py-4">
    <div class="row mb-4">
        <div class="col-12">
            <h1 class="display-4 mb-1">
                <i class="fas fa-chart-line me-2 text-primary"></i>
                Dashboard
            </h1>
            <p class="text-muted">Control panel and statistics</p>
        </div>
    </div>

    <!-- Statistics Cards -->
    <div class="row g-3 mb-4">
        <!-- Total Products -->
        <div class="col-12 col-sm-6 col-lg-3">
            <div class="card border-0 shadow-sm h-100">
                <div class="card-body">
                    <div class="d-flex justify-content-between align-items-start mb-3">
                        <div>
                            <p class="text-muted mb-1 small">Total Products</p>
                            <h2 class="mb-0 text-primary fw-bold">@StatisticsService.GetTotalProducts()</h2>
                        </div>
                        <div class="bg-primary bg-opacity-10 rounded p-3">
                            <i class="fas fa-box fa-2x text-primary"></i>
                        </div>
                    </div>
                    <small class="text-muted">
                        <i class="fas fa-info-circle me-1"></i>
                        In catalog
                    </small>
                </div>
            </div>
        </div>

        <!-- Total Inventory Value -->
        <div class="col-12 col-sm-6 col-lg-3">
            <div class="card border-0 shadow-sm h-100">
                <div class="card-body">
                    <div class="d-flex justify-content-between align-items-start mb-3">
                        <div>
                            <p class="text-muted mb-1 small">Inventory Value</p>
                            <h2 class="mb-0 text-success fw-bold">$@StatisticsService.GetTotalInventoryValue().ToString("N2")</h2>
                        </div>
                        <div class="bg-success bg-opacity-10 rounded p-3">
                            <i class="fas fa-dollar-sign fa-2x text-success"></i>
                        </div>
                    </div>
                    <small class="text-muted">
                        <i class="fas fa-info-circle me-1"></i>
                        Price × Stock
                    </small>
                </div>
            </div>
        </div>

        <!-- Low Stock Products -->
        <div class="col-12 col-sm-6 col-lg-3">
            <div class="card border-0 shadow-sm h-100">
                <div class="card-body">
                    <div class="d-flex justify-content-between align-items-start mb-3">
                        <div>
                            <p class="text-muted mb-1 small">Low Stock</p>
                            <h2 class="mb-0 text-warning fw-bold">@StatisticsService.GetLowStockProducts()</h2>
                        </div>
                        <div class="bg-warning bg-opacity-10 rounded p-3">
                            <i class="fas fa-exclamation-triangle fa-2x text-warning"></i>
                        </div>
                    </div>
                    <small class="text-muted">
                        <i class="fas fa-info-circle me-1"></i>
                        Less than 20 units
                    </small>
                </div>
            </div>
        </div>

        <!-- Pending Tasks -->
        <div class="col-12 col-sm-6 col-lg-3">
            <div class="card border-0 shadow-sm h-100">
                <div class="card-body">
                    <div class="d-flex justify-content-between align-items-start mb-3">
                        <div>
                            <p class="text-muted mb-1 small">Pending Tasks</p>
                            <h2 class="mb-0 text-danger fw-bold">@StatisticsService.GetPendingTasks()</h2>
                        </div>
                        <div class="bg-danger bg-opacity-10 rounded p-3">
                            <i class="fas fa-tasks fa-2x text-danger"></i>
                        </div>
                    </div>
                    <small class="text-muted">
                        <i class="fas fa-info-circle me-1"></i>
                        To complete
                    </small>
                </div>
            </div>
        </div>
    </div>

    <!-- Products by Category and Tasks by Status -->
    <div class="row g-3 mb-4">
        <!-- Products by Category -->
        <div class="col-12 col-lg-6">
            <div class="card border-0 shadow-sm h-100">
                <div class="card-header bg-white border-0 pt-3">
                    <h5 class="mb-0">
                        <i class="fas fa-layer-group me-2 text-primary"></i>
                        Products by Category
                    </h5>
                </div>
                <div class="card-body">
                    @{
                        var productsByCategory = StatisticsService.GetProductsByCategory();
                        var totalProducts = productsByCategory.Values.Sum();
                    }
                    @foreach (var category in productsByCategory.OrderByDescending(x => x.Value))
                    {
                        var percentage = totalProducts > 0 ? (category.Value * 100.0 / totalProducts) : 0;
                        <div class="mb-3">
                            <div class="d-flex justify-content-between mb-1">
                                <small class="fw-semibold">@category.Key</small>
                                <small class="text-muted">@category.Value products (@percentage.ToString("F1")%)</small>
                            </div>
                            <div class="progress" style="height: 8px;">
                                <div class="progress-bar bg-primary" role="progressbar"
                                     style="width: @percentage.ToString("F1")%"
                                     aria-valuenow="@percentage" aria-valuemin="0" aria-valuemax="100"></div>
                            </div>
                        </div>
                    }
                </div>
            </div>
        </div>

        <!-- Tasks by Status -->
        <div class="col-12 col-lg-6">
            <div class="card border-0 shadow-sm h-100">
                <div class="card-header bg-white border-0 pt-3">
                    <h5 class="mb-0">
                        <i class="fas fa-list-check me-2 text-success"></i>
                        Tasks by Status
                    </h5>
                </div>
                <div class="card-body">
                    @{
                        var tasksByStatus = StatisticsService.GetTasksByStatus();
                        var totalTasks = tasksByStatus.Values.Sum();
                    }
                    @foreach (var status in tasksByStatus)
                    {
                        var percentage = totalTasks > 0 ? (status.Value * 100.0 / totalTasks) : 0;
                        var statusName = status.Key switch
                        {
                            Models.TaskStatus.Pending => "Pending",
                            Models.TaskStatus.InProgress => "In Progress",
                            Models.TaskStatus.Completed => "Completed",
                            _ => status.Key.ToString()
                        };
                        var colorClass = status.Key switch
                        {
                            Models.TaskStatus.Pending => "warning",
                            Models.TaskStatus.InProgress => "info",
                            Models.TaskStatus.Completed => "success",
                            _ => "secondary"
                        };
                        <div class="mb-3">
                            <div class="d-flex justify-content-between mb-1">
                                <small class="fw-semibold">@statusName</small>
                                <small class="text-muted">@status.Value tasks (@percentage.ToString("F1")%)</small>
                            </div>
                            <div class="progress" style="height: 8px;">
                                <div class="progress-bar bg-@colorClass" role="progressbar"
                                     style="width: @percentage.ToString("F1")%"
                                     aria-valuenow="@percentage" aria-valuemin="0" aria-valuemax="100"></div>
                            </div>
                        </div>
                    }
                </div>
            </div>
        </div>
    </div>

    <!-- Pending Tasks by Priority -->
    <div class="row g-3 mb-4">
        <div class="col-12">
            <div class="card border-0 shadow-sm">
                <div class="card-header bg-white border-0 pt-3">
                    <h5 class="mb-0">
                        <i class="fas fa-flag me-2 text-danger"></i>
                        Pending Tasks by Priority
                    </h5>
                </div>
                <div class="card-body">
                    <div class="row g-3">
                        @{
                            var tasksByPriority = StatisticsService.GetTasksByPriority();
                        }
                        @foreach (var priority in tasksByPriority)
                        {
                            var priorityName = priority.Key switch
                            {
                                Models.TaskPriority.Low => "Low",
                                Models.TaskPriority.Medium => "Medium",
                                Models.TaskPriority.High => "High",
                                _ => priority.Key.ToString()
                            };
                            var colorClass = priority.Key switch
                            {
                                Models.TaskPriority.Low => "success",
                                Models.TaskPriority.Medium => "warning",
                                Models.TaskPriority.High => "danger",
                                _ => "secondary"
                            };
                            var iconClass = priority.Key switch
                            {
                                Models.TaskPriority.Low => "fa-arrow-down",
                                Models.TaskPriority.Medium => "fa-minus",
                                Models.TaskPriority.High => "fa-arrow-up",
                                _ => "fa-minus"
                            };
                            <div class="col-12 col-md-4">
                                <div class="card bg-@colorClass bg-opacity-10 border-@colorClass border-opacity-25">
                                    <div class="card-body text-center">
                                        <i class="fas @iconClass fa-2x text-@colorClass mb-2"></i>
                                        <h3 class="mb-0 fw-bold text-@colorClass">@priority.Value</h3>
                                        <small class="text-muted">@priorityName Priority</small>
                                    </div>
                                </div>
                            </div>
                        }
                    </div>
                </div>
            </div>
        </div>
    </div>

    <!-- Quick Actions -->
    <div class="row g-3">
        <div class="col-12">
            <div class="card border-0 shadow-sm">
                <div class="card-header bg-white border-0 pt-3">
                    <h5 class="mb-0">
                        <i class="fas fa-bolt me-2 text-warning"></i>
                        Quick Actions
                    </h5>
                </div>
                <div class="card-body">
                    <div class="row g-3">
                        <div class="col-12 col-md-4">
                            <button class="btn btn-primary w-100 py-3" @onclick="NavigateToProducts">
                                <i class="fas fa-box fa-2x mb-2 d-block"></i>
                                <span class="d-block">View Products</span>
                            </button>
                        </div>
                        <div class="col-12 col-md-4">
                            <button class="btn btn-success w-100 py-3" @onclick="NavigateToTasks">
                                <i class="fas fa-tasks fa-2x mb-2 d-block"></i>
                                <span class="d-block">View Tasks</span>
                            </button>
                        </div>
                        <div class="col-12 col-md-4">
                            <button class="btn btn-info w-100 py-3" @onclick="NavigateToComponents">
                                <i class="fas fa-cube fa-2x mb-2 d-block"></i>
                                <span class="d-block">View Components</span>
                            </button>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

@code {
    private void NavigateToProducts()
    {
        Navigation.NavigateTo("/products");
    }

    private void NavigateToTasks()
    {
        Navigation.NavigateTo("/tasks");
    }

    private void NavigateToComponents()
    {
        Navigation.NavigateTo("/components");
    }
}
