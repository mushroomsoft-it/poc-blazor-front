@page "/tasks"
@inject Services.TaskService TaskService
@inject NavigationManager Navigation
@using Bootstrap_POC.Components.DataGrid.Filters
@using Bootstrap_POC.Components.DataGrid.FilterPanel
@using Bootstrap_POC.Components.DataGrid.Extensions

<PageTitle>Tasks - Bootstrap POC</PageTitle>

<div class="container-fluid py-4">
    <div class="row mb-4">
        <div class="col-12">
            <div class="d-flex justify-content-between align-items-center">
                <div>
                    <h1 class="display-5 mb-1">
                        <i class="fas fa-tasks me-2 text-success"></i>
                        Tasks
                    </h1>
                    <p class="text-muted mb-0">Task and activity management</p>
                </div>
                <div>
                    <button class="btn btn-success btn-lg" @onclick="NewTask">
                        <i class="fas fa-plus me-2"></i>
                        New Task
                    </button>
                </div>
            </div>
        </div>
    </div>

    <!-- Search bar and Filter Panel -->
    <div class="row mb-4">
        <div class="col-12">
            <div class="card border-0 shadow-sm" style="overflow: visible;">
                <div class="card-body" style="overflow: visible;">
                    <div class="d-flex gap-3 align-items-center flex-wrap">
                        <!-- Search Input -->
                        <div class="input-group flex-grow-1" style="max-width: 400px;">
                            <span class="input-group-text bg-white">
                                <i class="fas fa-search text-muted"></i>
                            </span>
                            <input type="text" class="form-control" placeholder="Search by title or description..."
                                   @bind="searchTerm" @bind:event="oninput" @onkeyup="OnSearchChanged" />
                            @if (!string.IsNullOrWhiteSpace(searchTerm))
                            {
                                <button class="btn btn-outline-secondary" @onclick="ClearSearch">
                                    <i class="fas fa-times"></i>
                                </button>
                            }
                        </div>

                        <!-- Filter Panel -->
                        <FilterPanel Columns="@filterableColumns"
                                     ActiveFilters="@activeFilters"
                                     ActiveFiltersChanged="@(filters => { activeFilters = filters; })"
                                     OnFilterChanged="HandleFilterPanelChanged"
                                     SavedViews="@savedFilterViews"
                                     SavedViewsChanged="@(views => { savedFilterViews = views; })"
                                     ShowSaveView="true" />
                    </div>
                </div>
            </div>
        </div>
    </div>

    <!-- Tasks DataGrid -->
    <div class="row">
        <div class="col-12">
            <div class="card border-0 shadow-sm" style="overflow: visible;">
                <div class="card-body p-0" style="overflow: visible;">
                    <DataGrid TItem="Models.Task"
                              Items="@displayedTasks"
                              TotalCount="@filteredCount"
                              CurrentPage="@currentPage"
                              PageSize="10"
                              SortColumn="@sortColumn"
                              SortAscending="@sortAscending"
                              OnPageChanged="HandlePageChanged"
                              OnSortChanged="HandleSortChanged"
                              OnFilterChanged="HandleFilterChanged"
                              ShowFilters="false"
                              FixedLayout="true">
                        <Columns>
                            <GridColumn TItem="Models.Task" PropertyName="Completed" Width="80px" Filterable="true" Sortable="false">
                                <Template Context="task">
                                    <input class="form-check-input" type="checkbox" checked="@task.Completed"
                                           @onchange="@(() => ToggleCompleted(task.Id))" />
                                </Template>
                            </GridColumn>
                            <GridColumn TItem="Models.Task" PropertyName="Title" Width="250px">
                                <Template Context="task">
                                    <span class="@(task.Completed ? "text-decoration-line-through" : "fw-semibold")">
                                        @task.Title
                                    </span>
                                </Template>
                            </GridColumn>
                            <GridColumn TItem="Models.Task" PropertyName="Description" Width="auto" Sortable="false">
                                <Template Context="task">
                                    <small class="text-muted">
                                        @(task.Description.Length > 60 ? task.Description.Substring(0, 60) + "..." : task.Description)
                                    </small>
                                </Template>
                            </GridColumn>
                            <GridColumn TItem="Models.Task" PropertyName="Status" Width="150px">
                                <Template Context="task">
                                    @{
                                        var statusBadgeClass = task.Status switch
                                        {
                                            Models.TaskStatus.Pending => "bg-warning",
                                            Models.TaskStatus.InProgress => "bg-info",
                                            Models.TaskStatus.Completed => "bg-success",
                                            _ => "bg-secondary"
                                        };
                                    }
                                    <span class="badge @statusBadgeClass">
                                        @task.Status.ToString().Replace("InProgress", "In Progress")
                                    </span>
                                </Template>
                            </GridColumn>
                            <GridColumn TItem="Models.Task" PropertyName="Priority" Width="120px">
                                <Template Context="task">
                                    @{
                                        var priorityBadgeClass = task.Priority switch
                                        {
                                            Models.TaskPriority.High => "bg-danger",
                                            Models.TaskPriority.Medium => "bg-warning",
                                            Models.TaskPriority.Low => "bg-success",
                                            _ => "bg-secondary"
                                        };
                                    }
                                    <span class="badge @priorityBadgeClass">
                                        <i class="fas fa-flag me-1"></i>
                                        @task.Priority
                                    </span>
                                </Template>
                            </GridColumn>
                            <GridColumn TItem="Models.Task" PropertyName="DueDate" Width="140px" Format="dd/MM/yyyy" Title="Due Date">
                                <Template Context="task">
                                    @{
                                        var isOverdue = task.DueDate < DateTime.Now && !task.Completed;
                                    }
                                    @if (isOverdue)
                                    {
                                        <span class="text-danger fw-bold">
                                            <i class="fas fa-exclamation-circle me-1"></i>
                                            @task.DueDate.ToString("dd/MM/yyyy")
                                        </span>
                                    }
                                    else
                                    {
                                        <small class="text-muted">@task.DueDate.ToString("dd/MM/yyyy")</small>
                                    }
                                </Template>
                            </GridColumn>
                        </Columns>
                        <RowActions Context="task">
                            <div class="btn-group btn-group-sm">
                                <button class="btn btn-outline-primary" @onclick="@(() => EditTask(task.Id))">
                                    <i class="fas fa-edit"></i>
                                </button>
                                <button class="btn btn-outline-danger" @onclick="@(() => DeleteTask(task.Id))">
                                    <i class="fas fa-trash"></i>
                                </button>
                            </div>
                        </RowActions>
                        <EmptyContent>
                            <div class="text-center py-5">
                                <i class="fas fa-inbox fa-4x text-muted mb-3 d-block"></i>
                                <h5 class="text-muted">No tasks found</h5>
                                @if (activeFilters.Any() || !string.IsNullOrWhiteSpace(searchTerm))
                                {
                                    <p class="text-muted">Try different search filters</p>
                                    <div class="d-flex gap-2 justify-content-center">
                                        @if (!string.IsNullOrWhiteSpace(searchTerm))
                                        {
                                            <button class="btn btn-sm btn-outline-primary" @onclick="ClearSearch">
                                                <i class="fas fa-times me-2"></i>Clear search
                                            </button>
                                        }
                                        @if (activeFilters.Any())
                                        {
                                            <button class="btn btn-sm btn-outline-secondary" @onclick="ClearAllFilters">
                                                <i class="fas fa-filter me-2"></i>Clear filters
                                            </button>
                                        }
                                    </div>
                                }
                                else
                                {
                                    <p class="text-muted">Add your first task</p>
                                    <button class="btn btn-success" @onclick="NewTask">
                                        <i class="fas fa-plus me-2"></i>New Task
                                    </button>
                                }
                            </div>
                        </EmptyContent>
                    </DataGrid>
                </div>
            </div>
        </div>
    </div>
</div>

@code {
    private List<Models.Task> allTasks = new();
    private List<Models.Task> displayedTasks = new();
    private int filteredCount = 0;
    private string searchTerm = string.Empty;
    private string sortColumn = "DueDate";
    private bool sortAscending = true;
    private int currentPage = 1;
    private Dictionary<string, FilterState> activeFilters = new();
    private List<FilterView> savedFilterViews = new();

    // Define filterable columns for the FilterPanel
    private List<FilterableColumn> filterableColumns = new()
    {
        new FilterableColumn
        {
            PropertyName = "Title",
            DisplayName = "Title",
            FilterType = FilterType.String,
            PropertyType = typeof(string)
        },
        new FilterableColumn
        {
            PropertyName = "Status",
            DisplayName = "Status",
            FilterType = FilterType.Enum,
            PropertyType = typeof(Models.TaskStatus),
            EnumValues = Enum.GetValues(typeof(Models.TaskStatus))
        },
        new FilterableColumn
        {
            PropertyName = "Priority",
            DisplayName = "Priority",
            FilterType = FilterType.Enum,
            PropertyType = typeof(Models.TaskPriority),
            EnumValues = Enum.GetValues(typeof(Models.TaskPriority))
        },
        new FilterableColumn
        {
            PropertyName = "DueDate",
            DisplayName = "Due Date",
            FilterType = FilterType.Date,
            PropertyType = typeof(DateTime)
        },
        new FilterableColumn
        {
            PropertyName = "Completed",
            DisplayName = "Completed",
            FilterType = FilterType.Boolean,
            PropertyType = typeof(bool)
        }
    };

    protected override void OnInitialized()
    {
        LoadTasks();
    }

    private void LoadTasks()
    {
        allTasks = TaskService.GetAll();
        ApplyFiltersAndLoadPage();
    }

    private void OnSearchChanged()
    {
        currentPage = 1;
        ApplyFiltersAndLoadPage();
    }

    private void ClearSearch()
    {
        searchTerm = string.Empty;
        OnSearchChanged();
    }

    private void HandleFilterChanged(FilterChangeEventArgs args)
    {
        activeFilters = args.AllFilters;
        currentPage = 1;
        ApplyFiltersAndLoadPage();
    }

    private void HandleFilterPanelChanged(FilterChangeEventArgs args)
    {
        activeFilters = args.AllFilters;
        currentPage = 1;
        ApplyFiltersAndLoadPage();
    }

    private void HandleSortChanged((string Column, bool Ascending) sortInfo)
    {
        sortColumn = sortInfo.Column;
        sortAscending = sortInfo.Ascending;
        ApplyFiltersAndLoadPage();
    }

    private void HandlePageChanged(int page)
    {
        currentPage = page;
        ApplyFiltersAndLoadPage();
    }

    private void ClearAllFilters()
    {
        activeFilters.Clear();
        currentPage = 1;
        ApplyFiltersAndLoadPage();
    }

    private void ApplyFiltersAndLoadPage()
    {
        var filtered = allTasks.AsEnumerable();

        // Apply search term
        if (!string.IsNullOrWhiteSpace(searchTerm))
        {
            filtered = filtered.Where(t =>
                t.Title.Contains(searchTerm, StringComparison.OrdinalIgnoreCase) ||
                t.Description.Contains(searchTerm, StringComparison.OrdinalIgnoreCase));
        }

        // Apply column filters
        foreach (var filter in activeFilters.Values)
        {
            filtered = ApplyFilter(filtered, filter);
        }

        // Apply sorting
        filtered = ApplySorting(filtered);

        var filteredList = filtered.ToList();
        filteredCount = filteredList.Count;

        // Apply pagination
        displayedTasks = filteredList
            .Skip((currentPage - 1) * 10)
            .Take(10)
            .ToList();

        StateHasChanged();
    }

    private IEnumerable<Models.Task> ApplyFilter(IEnumerable<Models.Task> tasks, FilterState filter)
    {
        return filter.PropertyName switch
        {
            "Title" => ApplyStringFilter(tasks, t => t.Title, filter),
            "Description" => ApplyStringFilter(tasks, t => t.Description, filter),
            "Status" => ApplyEnumFilter(tasks, t => t.Status, filter),
            "Priority" => ApplyEnumFilter(tasks, t => t.Priority, filter),
            "DueDate" => ApplyDateFilter(tasks, t => t.DueDate, filter),
            "Completed" => ApplyBooleanFilter(tasks, t => t.Completed, filter),
            _ => tasks
        };
    }

    private IEnumerable<Models.Task> ApplyStringFilter(IEnumerable<Models.Task> tasks, Func<Models.Task, string> selector, FilterState filter)
    {
        if (filter.Value == null) return tasks;
        var filterValue = filter.Value.ToString() ?? string.Empty;

        return filter.Operator switch
        {
            FilterOperator.Contains => tasks.Where(t => selector(t).Contains(filterValue, StringComparison.OrdinalIgnoreCase)),
            FilterOperator.Equals => tasks.Where(t => selector(t).Equals(filterValue, StringComparison.OrdinalIgnoreCase)),
            FilterOperator.StartsWith => tasks.Where(t => selector(t).StartsWith(filterValue, StringComparison.OrdinalIgnoreCase)),
            FilterOperator.EndsWith => tasks.Where(t => selector(t).EndsWith(filterValue, StringComparison.OrdinalIgnoreCase)),
            _ => tasks
        };
    }

    private IEnumerable<Models.Task> ApplyEnumFilter<TEnum>(IEnumerable<Models.Task> tasks, Func<Models.Task, TEnum> selector, FilterState filter)
        where TEnum : Enum
    {
        if (filter.Value == null) return tasks;
        var filterValue = (TEnum)filter.Value;

        return filter.Operator switch
        {
            FilterOperator.Equals => tasks.Where(t => selector(t).Equals(filterValue)),
            _ => tasks
        };
    }

    private IEnumerable<Models.Task> ApplyBooleanFilter(IEnumerable<Models.Task> tasks, Func<Models.Task, bool> selector, FilterState filter)
    {
        if (filter.Value == null) return tasks;
        var filterValue = (bool)filter.Value;

        return filter.Operator switch
        {
            FilterOperator.Equals => tasks.Where(t => selector(t) == filterValue),
            _ => tasks
        };
    }

    private IEnumerable<Models.Task> ApplyDateFilter(IEnumerable<Models.Task> tasks, Func<Models.Task, DateTime> selector, FilterState filter)
    {
        if (filter.Value == null) return tasks;
        var filterDate = (DateTime)filter.Value;

        return filter.Operator switch
        {
            FilterOperator.Equals => tasks.Where(t => selector(t).Date == filterDate.Date),
            FilterOperator.After => tasks.Where(t => selector(t).Date > filterDate.Date),
            FilterOperator.Before => tasks.Where(t => selector(t).Date < filterDate.Date),
            FilterOperator.GreaterThan => tasks.Where(t => selector(t).Date > filterDate.Date),
            FilterOperator.LessThan => tasks.Where(t => selector(t).Date < filterDate.Date),
            FilterOperator.Between when filter.Value2 != null =>
                tasks.Where(t => selector(t).Date >= filterDate.Date && selector(t).Date <= ((DateTime)filter.Value2).Date),
            _ => tasks
        };
    }

    private IEnumerable<Models.Task> ApplySorting(IEnumerable<Models.Task> tasks)
    {
        return sortColumn switch
        {
            "Title" => sortAscending ? tasks.OrderBy(t => t.Title) : tasks.OrderByDescending(t => t.Title),
            "Status" => sortAscending ? tasks.OrderBy(t => t.Status) : tasks.OrderByDescending(t => t.Status),
            "Priority" => sortAscending ? tasks.OrderBy(t => t.Priority) : tasks.OrderByDescending(t => t.Priority),
            "DueDate" => sortAscending ? tasks.OrderBy(t => t.DueDate) : tasks.OrderByDescending(t => t.DueDate),
            _ => tasks
        };
    }

    private void ToggleCompleted(int id)
    {
        TaskService.ToggleCompleted(id);
        LoadTasks();
    }

    private void NewTask()
    {
        Navigation.NavigateTo("/tasks/new");
    }

    private void EditTask(int id)
    {
        Navigation.NavigateTo($"/tasks/edit/{id}");
    }

    private void DeleteTask(int id)
    {
        // In production, this should be a Bootstrap confirmation modal
        TaskService.Delete(id);
        LoadTasks();
    }
}
