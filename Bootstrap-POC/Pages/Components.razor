@page "/components"

<PageTitle>Components - Bootstrap POC</PageTitle>

<div class="container-fluid py-4">
    <div class="row mb-4">
        <div class="col-12">
            <h1 class="display-5 mb-1">
                <i class="fas fa-cube me-2 text-info"></i>
                Bootstrap 5 Components
            </h1>
            <p class="text-muted">Showcase of available Bootstrap 5 components</p>
        </div>
    </div>

    <!-- Tabs Navigation -->
    <ul class="nav nav-pills mb-4" id="componentsTab" role="tablist">
        <li class="nav-item" role="presentation">
            <button class="nav-link @(activeTab == "buttons" ? "active" : "")" @onclick='() => ChangeTab("buttons")'>
                <i class="fas fa-hand-pointer me-2"></i>Buttons
            </button>
        </li>
        <li class="nav-item" role="presentation">
            <button class="nav-link @(activeTab == "forms" ? "active" : "")" @onclick='() => ChangeTab("forms")'>
                <i class="fas fa-edit me-2"></i>Forms
            </button>
        </li>
        <li class="nav-item" role="presentation">
            <button class="nav-link @(activeTab == "alerts" ? "active" : "")" @onclick='() => ChangeTab("alerts")'>
                <i class="fas fa-exclamation-circle me-2"></i>Alerts & Modals
            </button>
        </li>
        <li class="nav-item" role="presentation">
            <button class="nav-link @(activeTab == "cards" ? "active" : "")" @onclick='() => ChangeTab("cards")'>
                <i class="fas fa-id-card me-2"></i>Cards & Badges
            </button>
        </li>
        <li class="nav-item" role="presentation">
            <button class="nav-link @(activeTab == "progress" ? "active" : "")" @onclick='() => ChangeTab("progress")'>
                <i class="fas fa-spinner me-2"></i>Progress & Icons
            </button>
        </li>
        <li class="nav-item" role="presentation">
            <button class="nav-link @(activeTab == "other" ? "active" : "")" @onclick='() => ChangeTab("other")'>
                <i class="fas fa-th me-2"></i>Other
            </button>
        </li>
    </ul>

    <!-- Tab Content -->
    <div class="tab-content">
        @if (activeTab == "buttons")
        {
            <div class="card border-0 shadow-sm">
                <div class="card-header bg-white">
                    <h4 class="mb-0">Buttons</h4>
                </div>
                <div class="card-body">
                    <div class="row g-4">
                        <!-- Botones Estándar -->
                        <div class="col-12">
                            <h5>Standard Buttons</h5>
                            <div class="d-flex flex-wrap gap-2">
                                <button class="btn btn-primary">Primary</button>
                                <button class="btn btn-secondary">Secondary</button>
                                <button class="btn btn-success">Success</button>
                                <button class="btn btn-danger">Danger</button>
                                <button class="btn btn-warning">Warning</button>
                                <button class="btn btn-info">Info</button>
                                <button class="btn btn-light">Light</button>
                                <button class="btn btn-dark">Dark</button>
                                <button class="btn btn-link">Link</button>
                            </div>
                        </div>

                        <!-- Botones Outline -->
                        <div class="col-12">
                            <h5>Outline Buttons</h5>
                            <div class="d-flex flex-wrap gap-2">
                                <button class="btn btn-outline-primary">Primary</button>
                                <button class="btn btn-outline-secondary">Secondary</button>
                                <button class="btn btn-outline-success">Success</button>
                                <button class="btn btn-outline-danger">Danger</button>
                                <button class="btn btn-outline-warning">Warning</button>
                                <button class="btn btn-outline-info">Info</button>
                                <button class="btn btn-outline-dark">Dark</button>
                            </div>
                        </div>

                        <!-- Botones con Iconos -->
                        <div class="col-12">
                            <h5>Buttons with icons</h5>
                            <div class="d-flex flex-wrap gap-2">
                                <button class="btn btn-primary">
                                    <i class="fas fa-download me-2"></i>Descargar
                                </button>
                                <button class="btn btn-success">
                                    <i class="fas fa-check me-2"></i>Save
                                </button>
                                <button class="btn btn-danger">
                                    <i class="fas fa-trash me-2"></i>Delete
                                </button>
                                <button class="btn btn-info">
                                    <i class="fas fa-info-circle me-2"></i>Info
                                </button>
                            </div>
                        </div>

                        <!-- Tamaños -->
                        <div class="col-12">
                            <h5>Sizes</h5>
                            <div class="d-flex flex-wrap gap-2 align-items-center">
                                <button class="btn btn-primary btn-lg">Grande</button>
                                <button class="btn btn-primary">Normal</button>
                                <button class="btn btn-primary btn-sm">Pequeño</button>
                            </div>
                        </div>

                        <!-- Estados -->
                        <div class="col-12">
                            <h5>Status</h5>
                            <div class="d-flex flex-wrap gap-2">
                                <button class="btn btn-primary">Normal</button>
                                <button class="btn btn-primary" disabled>Deshabilitado</button>
                                <button class="btn btn-primary" disabled>
                                    <span class="spinner-border spinner-border-sm me-2" role="status"></span>
                                    Cargando...
                                </button>
                            </div>
                        </div>

                        <!-- Button Groups -->
                        <div class="col-12">
                            <h5>Button Groups</h5>
                            <div class="btn-group" role="group">
                                <button type="button" class="btn btn-primary">Izquierda</button>
                                <button type="button" class="btn btn-primary">Centro</button>
                                <button type="button" class="btn btn-primary">Derecha</button>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        }

        @if (activeTab == "forms")
        {
            <div class="card border-0 shadow-sm">
                <div class="card-header bg-white">
                    <h4 class="mb-0">Forms</h4>
                </div>
                <div class="card-body">
                    <div class="row g-4">
                        <!-- Inputs de Texto -->
                        <div class="col-12 col-md-6">
                            <h5>Text Inputs</h5>
                            <div class="mb-3">
                                <label class="form-label">Normal Text</label>
                                <input type="text" class="form-control" placeholder="Enter text" />
                            </div>
                            <div class="mb-3">
                                <label class="form-label">Email</label>
                                <input type="email" class="form-control" placeholder="joe@mail.com" />
                            </div>
                            <div class="mb-3">
                                <label class="form-label">Password</label>
                                <input type="password" class="form-control" placeholder="Password" />
                            </div>
                            <div class="mb-3">
                                <label class="form-label">Número</label>
                                <input type="number" class="form-control" placeholder="123" />
                            </div>
                        </div>

                        <!-- Textarea y Select -->
                        <div class="col-12 col-md-6">
                            <h5>Textarea y Select</h5>
                            <div class="mb-3">
                                <label class="form-label">Textarea</label>
                                <textarea class="form-control" rows="3" placeholder="Enter commentaries"></textarea>
                            </div>
                            <div class="mb-3">
                                <label class="form-label">Select</label>
                                <select class="form-select">
                                    <option selected>Choose one option</option>
                                    <option value="1">Option 1</option>
                                    <option value="2">Option 2</option>
                                    <option value="3">Option 3</option>
                                </select>
                            </div>
                        </div>

                        <!-- Checkboxes y Radios -->
                        <div class="col-12 col-md-6">
                            <h5>Checkboxes</h5>
                            <div class="form-check">
                                <input class="form-check-input" type="checkbox" id="check1" checked />
                                <label class="form-check-label" for="check1">Option 1</label>
                            </div>
                            <div class="form-check">
                                <input class="form-check-input" type="checkbox" id="check2" />
                                <label class="form-check-label" for="check2">Option 2</label>
                            </div>
                            <div class="form-check">
                                <input class="form-check-input" type="checkbox" id="check3" disabled />
                                <label class="form-check-label" for="check3">Option 3 (deshabilitada)</label>
                            </div>
                        </div>

                        <div class="col-12 col-md-6">
                            <h5>Radio Buttons</h5>
                            <div class="form-check">
                                <input class="form-check-input" type="radio" name="radios" id="radio1" checked />
                                <label class="form-check-label" for="radio1">Option 1</label>
                            </div>
                            <div class="form-check">
                                <input class="form-check-input" type="radio" name="radios" id="radio2" />
                                <label class="form-check-label" for="radio2">Option 2</label>
                            </div>
                            <div class="form-check">
                                <input class="form-check-input" type="radio" name="radios" id="radio3" />
                                <label class="form-check-label" for="radio3">Option 3</label>
                            </div>
                        </div>

                        <!-- Switches y Range -->
                        <div class="col-12 col-md-6">
                            <h5>Switches</h5>
                            <div class="form-check form-switch">
                                <input class="form-check-input" type="checkbox" id="switch1" checked />
                                <label class="form-check-label" for="switch1">Option activated</label>
                            </div>
                            <div class="form-check form-switch">
                                <input class="form-check-input" type="checkbox" id="switch2" />
                                <label class="form-check-label" for="switch2">Option disabled</label>
                            </div>
                        </div>

                        <div class="col-12 col-md-6">
                            <h5>Range Slider</h5>
                            <label for="customRange" class="form-label">Slider's example: @rangeValue</label>
                            <input type="range" class="form-range" id="customRange" @bind="rangeValue" min="0" max="100" />
                        </div>

                        <!-- Input Groups -->
                        <div class="col-12">
                            <h5>Input Groups</h5>
                            <div class="mb-3">
                                <div class="input-group">
                                    <span class="input-group-text">@@</span>
                                    <input type="text" class="form-control" placeholder="Username" />
                                </div>
                            </div>
                            <div class="mb-3">
                                <div class="input-group">
                                    <span class="input-group-text">$</span>
                                    <input type="text" class="form-control" placeholder="0.00" />
                                    <span class="input-group-text">.00</span>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        }

        @if (activeTab == "alerts")
        {
            <div class="card border-0 shadow-sm">
                <div class="card-header bg-white">
                    <h4 class="mb-0">Alerts and Modals</h4>
                </div>
                <div class="card-body">
                    <div class="row g-4">
                        <!-- Alertas -->
                        <div class="col-12">
                            <h5>Warnings</h5>
                            <div class="alert alert-primary" role="alert">
                                <i class="fas fa-info-circle me-2"></i>
                                This is an informational alert. - Primary
                            </div>
                            <div class="alert alert-success" role="alert">
                                <i class="fas fa-check-circle me-2"></i>
                                Operation successful! - Success
                            </div>
                            <div class="alert alert-warning" role="alert">
                                <i class="fas fa-exclamation-triangle me-2"></i>
                                Warning: Review this information - Warning
                            </div>
                            <div class="alert alert-danger" role="alert">
                                <i class="fas fa-times-circle me-2"></i>
                                Error: Something went wrong - Danger
                            </div>
                            <div class="alert alert-info" role="alert">
                                <i class="fas fa-lightbulb me-2"></i>
                                Useful information - Info
                            </div>
                        </div>

                        <!-- Alertas Dismissible -->
                        <div class="col-12">
                            <h5>Closable Warnings</h5>
                            @if (showDismissibleAlert)
                            {
                                <div class="alert alert-warning alert-dismissible fade show" role="alert">
                                    <i class="fas fa-exclamation-triangle me-2"></i>
                                    This warning can be closed by clicking the X
                                    <button type="button" class="btn-close" @onclick="() => showDismissibleAlert = false"></button>
                                </div>
                            }
                            else
                            {
                                <button class="btn btn-outline-primary" @onclick="() => showDismissibleAlert = true">
                                    Show closable warning
                                </button>
                            }
                        </div>

                        <!-- Toast Notifications -->
                        <div class="col-12">
                            <h5>Toast Notifications</h5>
                            <button class="btn btn-primary" @onclick="ShowToast">Show Toast</button>
                            @if (showToast)
                            {
                                <div class="position-fixed bottom-0 end-0 p-3" style="z-index: 11">
                                    <div class="toast show" role="alert">
                                        <div class="toast-header">
                                            <i class="fas fa-bell me-2 text-primary"></i>
                                            <strong class="me-auto">Notification</strong>
                                            <small>Ahora</small>
                                            <button type="button" class="btn-close" @onclick="() => showToast = false"></button>
                                        </div>
                                        <div class="toast-body">
                                            ¡This is a Bootstrap's toast notification!
                                        </div>
                                    </div>
                                </div>
                            }
                        </div>

                        <!-- Modal -->
                        <div class="col-12">
                            <h5>Modal</h5>
                            <button class="btn btn-primary" @onclick="OpenModal">Open Modal</button>
                            @if (showModal)
                            {
                                <div class="modal fade show d-block" tabindex="-1" style="background-color: rgba(0,0,0,0.5);">
                                    <div class="modal-dialog modal-dialog-centered">
                                        <div class="modal-content">
                                            <div class="modal-header">
                                                <h5 class="modal-title">
                                                    <i class="fas fa-window-maximize me-2"></i>
                                                    Modal Title
                                                </h5>
                                                <button type="button" class="btn-close" @onclick="CloseModal"></button>
                                            </div>
                                            <div class="modal-body">
                                                <p>This is the modal's content. Here you can enter any HTML content.</p>
                                                <div class="alert alert-info mb-0">
                                                    <i class="fas fa-info-circle me-2"></i>
                                                    Modals are useful for forms.
                                                </div>
                                            </div>
                                            <div class="modal-footer">
                                                <button type="button" class="btn btn-secondary" @onclick="CloseModal">Close</button>
                                                <button type="button" class="btn btn-primary">Save</button>
                                            </div>
                                        </div>
                                    </div>
                                </div>
                            }
                        </div>
                    </div>
                </div>
            </div>
        }

        @if (activeTab == "cards")
        {
            <div class="card border-0 shadow-sm">
                <div class="card-header bg-white">
                    <h4 class="mb-0">Cards and Badges</h4>
                </div>
                <div class="card-body">
                    <div class="row g-4">
                        <!-- Cards Básicas -->
                        <div class="col-12">
                            <h5>Cards</h5>
                        </div>
                        <div class="col-12 col-md-4">
                            <div class="card">
                                <div class="card-header">Card Header</div>
                                <div class="card-body">
                                    <h5 class="card-title">Card's title</h5>
                                    <p class="card-text">Card's content with text example.</p>
                                    <button class="btn btn-primary">Action</button>
                                </div>
                            </div>
                        </div>
                        <div class="col-12 col-md-4">
                            <div class="card border-primary">
                                <div class="card-header bg-primary text-white">Coloured card</div>
                                <div class="card-body">
                                    <h5 class="card-title">Coloured card</h5>
                                    <p class="card-text">This card has edges</p>
                                    <button class="btn btn-outline-primary">Action</button>
                                </div>
                            </div>
                        </div>
                        <div class="col-12 col-md-4">
                            <div class="card text-white bg-dark">
                                <div class="card-body">
                                    <h5 class="card-title">Dark card</h5>
                                    <p class="card-text">Dark card with bright text.</p>
                                    <button class="btn btn-light">Action</button>
                                </div>
                            </div>
                        </div>

                        <!-- Badges -->
                        <div class="col-12">
                            <h5>Badges</h5>
                            <div class="d-flex flex-wrap gap-2">
                                <span class="badge bg-primary">Primary</span>
                                <span class="badge bg-secondary">Secondary</span>
                                <span class="badge bg-success">Success</span>
                                <span class="badge bg-danger">Danger</span>
                                <span class="badge bg-warning text-dark">Warning</span>
                                <span class="badge bg-info text-dark">Info</span>
                                <span class="badge bg-light text-dark">Light</span>
                                <span class="badge bg-dark">Dark</span>
                            </div>
                        </div>

                        <!-- Badges Pill -->
                        <div class="col-12">
                            <h5>Badges Pill</h5>
                            <div class="d-flex flex-wrap gap-2">
                                <span class="badge rounded-pill bg-primary">Primary</span>
                                <span class="badge rounded-pill bg-secondary">Secondary</span>
                                <span class="badge rounded-pill bg-success">Success</span>
                                <span class="badge rounded-pill bg-danger">Danger</span>
                            </div>
                        </div>

                        <!-- Badges con Iconos -->
                        <div class="col-12">
                            <h5>Badges with icons</h5>
                            <div class="d-flex flex-wrap gap-2">
                                <span class="badge bg-primary">
                                    <i class="fas fa-user me-1"></i> 5 Users
                                </span>
                                <span class="badge bg-success">
                                    <i class="fas fa-check me-1"></i> Completed
                                </span>
                                <span class="badge bg-warning text-dark">
                                    <i class="fas fa-clock me-1"></i> Pending
                                </span>
                                <span class="badge bg-danger">
                                    <i class="fas fa-times me-1"></i> Error
                                </span>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        }

        @if (activeTab == "progress")
        {
            <div class="card border-0 shadow-sm">
                <div class="card-header bg-white">
                    <h4 class="mb-0">Progress and Icons</h4>
                </div>
                <div class="card-body">
                    <div class="row g-4">
                        <!-- Progress Bars -->
                        <div class="col-12">
                            <h5>Progress Bars</h5>
                            <div class="mb-3">
                                <label class="form-label">25%</label>
                                <div class="progress">
                                    <div class="progress-bar" role="progressbar" style="width: 25%" aria-valuenow="25" aria-valuemin="0" aria-valuemax="100"></div>
                                </div>
                            </div>
                            <div class="mb-3">
                                <label class="form-label">50%</label>
                                <div class="progress">
                                    <div class="progress-bar bg-success" role="progressbar" style="width: 50%" aria-valuenow="50" aria-valuemin="0" aria-valuemax="100"></div>
                                </div>
                            </div>
                            <div class="mb-3">
                                <label class="form-label">75%</label>
                                <div class="progress">
                                    <div class="progress-bar bg-info" role="progressbar" style="width: 75%" aria-valuenow="75" aria-valuemin="0" aria-valuemax="100"></div>
                                </div>
                            </div>
                            <div class="mb-3">
                                <label class="form-label">100%</label>
                                <div class="progress">
                                    <div class="progress-bar bg-danger" role="progressbar" style="width: 100%" aria-valuenow="100" aria-valuemin="0" aria-valuemax="100"></div>
                                </div>
                            </div>
                        </div>

                        <!-- Progress Striped and Animated -->
                        <div class="col-12">
                            <h5>Progress Striped and Animated</h5>
                            <div class="mb-3">
                                <label class="form-label">Striped</label>
                                <div class="progress">
                                    <div class="progress-bar progress-bar-striped" role="progressbar" style="width: 60%" aria-valuenow="60" aria-valuemin="0" aria-valuemax="100"></div>
                                </div>
                            </div>
                            <div class="mb-3">
                                <label class="form-label">Animated</label>
                                <div class="progress">
                                    <div class="progress-bar progress-bar-striped progress-bar-animated" role="progressbar" style="width: 75%" aria-valuenow="75" aria-valuemin="0" aria-valuemax="100"></div>
                                </div>
                            </div>
                        </div>

                        <!-- Spinners -->
                        <div class="col-12">
                            <h5>Spinners</h5>
                            <div class="d-flex flex-wrap gap-3">
                                <div class="spinner-border text-primary" role="status">
                                    <span class="visually-hidden">Loading...</span>
                                </div>
                                <div class="spinner-border text-success" role="status">
                                    <span class="visually-hidden">Loading...</span>
                                </div>
                                <div class="spinner-border text-danger" role="status">
                                    <span class="visually-hidden">Loading...</span>
                                </div>
                                <div class="spinner-grow text-primary" role="status">
                                    <span class="visually-hidden">Loading...</span>
                                </div>
                                <div class="spinner-grow text-success" role="status">
                                    <span class="visually-hidden">Loading...</span>
                                </div>
                                <div class="spinner-grow text-danger" role="status">
                                    <span class="visually-hidden">Loading...</span>
                                </div>
                            </div>
                        </div>

                        <!-- Font Awesome Icons -->
                        <div class="col-12">
                            <h5>Font Awesome Icons</h5>
                            <div class="row g-3">
                                <div class="col-auto">
                                    <i class="fas fa-home fa-2x text-primary"></i>
                                </div>
                                <div class="col-auto">
                                    <i class="fas fa-user fa-2x text-success"></i>
                                </div>
                                <div class="col-auto">
                                    <i class="fas fa-cog fa-2x text-secondary"></i>
                                </div>
                                <div class="col-auto">
                                    <i class="fas fa-heart fa-2x text-danger"></i>
                                </div>
                                <div class="col-auto">
                                    <i class="fas fa-star fa-2x text-warning"></i>
                                </div>
                                <div class="col-auto">
                                    <i class="fas fa-envelope fa-2x text-info"></i>
                                </div>
                                <div class="col-auto">
                                    <i class="fas fa-bell fa-2x text-dark"></i>
                                </div>
                                <div class="col-auto">
                                    <i class="fas fa-shopping-cart fa-2x text-success"></i>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        }

        @if (activeTab == "other")
        {
            <div class="card border-0 shadow-sm">
                <div class="card-header bg-white">
                    <h4 class="mb-0">Other Components</h4>
                </div>
                <div class="card-body">
                    <div class="row g-4">
                        <!-- Accordion -->
                        <div class="col-12">
                            <h5>Accordion</h5>
                            <div class="accordion" id="accordionExample">
                                <div class="accordion-item">
                                    <h2 class="accordion-header">
                                        <button class="accordion-button" type="button" @onclick='() => ToggleAccordion(1)'>
                                            Accordion Item #1
                                        </button>
                                    </h2>
                                    @if (activeAccordion == 1)
                                    {
                                        <div class="accordion-collapse collapse show">
                                            <div class="accordion-body">
                                                This is the content of the first item of the accordion. You can put any content here.
                                            </div>
                                        </div>
                                    }
                                </div>
                                <div class="accordion-item">
                                    <h2 class="accordion-header">
                                        <button class="accordion-button collapsed" type="button" @onclick='() => ToggleAccordion(2)'>
                                            Accordion Item #2
                                        </button>
                                    </h2>
                                    @if (activeAccordion == 2)
                                    {
                                        <div class="accordion-collapse collapse show">
                                            <div class="accordion-body">
                                                This is the content of the second item of the accordion..
                                            </div>
                                        </div>
                                    }
                                </div>
                                <div class="accordion-item">
                                    <h2 class="accordion-header">
                                        <button class="accordion-button collapsed" type="button" @onclick='() => ToggleAccordion(3)'>
                                            Accordion Item #3
                                        </button>
                                    </h2>
                                    @if (activeAccordion == 3)
                                    {
                                        <div class="accordion-collapse collapse show">
                                            <div class="accordion-body">
                                                This is the content of the third item of the accordion.
                                            </div>
                                        </div>
                                    }
                                </div>
                            </div>
                        </div>

                        <!-- Breadcrumb -->
                        <div class="col-12">
                            <h5>Breadcrumb</h5>
                            <nav aria-label="breadcrumb">
                                <ol class="breadcrumb">
                                    <li class="breadcrumb-item"><a href="#">Home</a></li>
                                    <li class="breadcrumb-item"><a href="#">Library</a></li>
                                    <li class="breadcrumb-item active" aria-current="page">Data</li>
                                </ol>
                            </nav>
                        </div>

                        <!-- Pagination -->
                        <div class="col-12">
                            <h5>Pagination</h5>
                            <nav>
                                <ul class="pagination">
                                    <li class="page-item disabled">
                                        <a class="page-link" href="#" tabindex="-1">Previous</a>
                                    </li>
                                    <li class="page-item active"><a class="page-link" href="#">1</a></li>
                                    <li class="page-item"><a class="page-link" href="#">2</a></li>
                                    <li class="page-item"><a class="page-link" href="#">3</a></li>
                                    <li class="page-item">
                                        <a class="page-link" href="#">Next</a>
                                    </li>
                                </ul>
                            </nav>
                        </div>

                        <!-- List Group -->
                        <div class="col-12 col-md-6">
                            <h5>List Group</h5>
                            <ul class="list-group">
                                <li class="list-group-item active">Active  item</li>
                                <li class="list-group-item">Normal item</li>
                                <li class="list-group-item">Other item</li>
                                <li class="list-group-item disabled">Disabled item</li>
                            </ul>
                        </div>

                        <!-- List Group with Badges -->
                        <div class="col-12 col-md-6">
                            <h5>List Group with Badges</h5>
                            <ul class="list-group">
                                <li class="list-group-item d-flex justify-content-between align-items-center">
                                    Inbox
                                    <span class="badge bg-primary rounded-pill">14</span>
                                </li>
                                <li class="list-group-item d-flex justify-content-between align-items-center">
                                    Sent
                                    <span class="badge bg-success rounded-pill">2</span>
                                </li>
                                <li class="list-group-item d-flex justify-content-between align-items-center">
                                    Drafts
                                    <span class="badge bg-warning text-dark rounded-pill">1</span>
                                </li>
                            </ul>
                        </div>

                        <!-- Tooltips -->
                        <div class="col-12">
                            <h5>Tooltips</h5>
                            <p class="text-muted">
                                <i class="fas fa-info-circle me-1"></i>
                                Tooltips require Javascript to work
                            </p>
                            <div class="d-flex gap-2">
                                <button type="button" class="btn btn-secondary" title="Tooltip on top">
                                    Upper tooltip
                                </button>
                                <button type="button" class="btn btn-secondary" title="Tooltip on right">
                                    Right tooltip
                                </button>
                                <button type="button" class="btn btn-secondary" title="Tooltip on bottom">
                                    Down tooltip
                                </button>
                                <button type="button" class="btn btn-secondary" title="Tooltip on left">
                                    Left tooltip
                                </button>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        }
    </div>
</div>

@code {
    private string activeTab = "buttons";
    private int rangeValue = 50;
    private bool showDismissibleAlert = true;
    private bool showToast = false;
    private bool showModal = false;
    private int activeAccordion = 1;

    private void ChangeTab(string tab)
    {
        activeTab = tab;
    }

    private void ShowToast()
    {
        showToast = true;
        StateHasChanged();
        System.Threading.Tasks.Task.Delay(3000).ContinueWith(t =>
        {
            showToast = false;
            InvokeAsync(StateHasChanged);
        });
    }

    private void OpenModal()
    {
        showModal = true;
    }

    private void CloseModal()
    {
        showModal = false;
    }

    private void ToggleAccordion(int item)
    {
        activeAccordion = activeAccordion == item ? 0 : item;
    }
}
